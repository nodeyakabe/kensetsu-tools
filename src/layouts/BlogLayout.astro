---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  heroImage?: string;
  tags?: string[];
  category?: string;
  slug: string;
}

const { title, description, publishedAt, updatedAt, heroImage, tags = [], category, slug } = Astro.props;

const siteUrl = (import.meta.env.SITE ?? 'https://kensetsu-tools.com').replace(/\/$/, '');
const canonicalUrl = `${siteUrl}/blog/${slug}/`;

const formattedDate = publishedAt.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).replace(/\//g, '-');

const updatedFormatted = updatedAt?.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).replace(/\//g, '-');

// BlogPosting 構造化データ
const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  ...(heroImage ? { image: [new URL(heroImage, siteUrl).href] } : {}),
  datePublished: publishedAt.toISOString(),
  dateModified: (updatedAt ?? publishedAt).toISOString(),
  ...(category ? { articleSection: category } : {}),
  ...(tags.length > 0 ? { keywords: tags.join(', ') } : {}),
  author: {
    '@type': 'Organization',
    name: '建設業ツール工房',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: '建設業ツール工房',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/apple-touch-icon.png`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
});

// BreadcrumbList 構造化データ
const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'ホーム',
      item: siteUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'ブログ',
      item: `${siteUrl}/blog/`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: canonicalUrl,
    },
  ],
});
---

<BaseLayout
  title={title}
  description={description}
  ogImage={heroImage}
  ogType="article"
  canonicalUrl={canonicalUrl}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={articleSchema} />
    <script type="application/ld+json" set:html={breadcrumbSchema} />
  </Fragment>

  <div class="w-full bg-white border-b border-[#D8DEE8]">
    <div class="max-w-[1160px] mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="text-sm text-[#5A6B85]" aria-label="パンくずリスト">
        <a href="/" class="hover:text-[#0F2557] transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <a href="/blog/" class="hover:text-[#0F2557] transition-colors">ブログ</a>
        <span class="mx-2">/</span>
        <span class="text-[#1A2B4A]">{title}</span>
      </nav>
    </div>
  </div>

  <div class="max-w-[1160px] mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <article class="max-w-3xl mx-auto">
      <!-- Category & Tags -->
      <div class="flex flex-wrap items-center gap-2 mb-4">
        {category && (
          <span class="text-[11px] font-bold bg-[#FDEBC8] text-[#B45309] px-3 py-1 rounded-full">
            {category}
          </span>
        )}
        {tags.map(tag => (
          <span class="text-xs font-medium bg-[#EFF2F7] text-[#44536E] px-3 py-1 rounded-full">
            #{tag}
          </span>
        ))}
      </div>

      <h1 class="text-3xl md:text-4xl font-black text-[#0F2557] leading-tight mb-4">
        {title}
      </h1>

      <div class="flex items-center gap-4 font-mono text-sm text-[#5A6B85] mb-8 pb-8 border-b border-[#D8DEE8]">
        <time datetime={publishedAt.toISOString()}>公開: {formattedDate}</time>
        {updatedAt && (
          <time datetime={updatedAt.toISOString()}>更新: {updatedFormatted}</time>
        )}
      </div>

      {heroImage && (
        <img
          src={heroImage}
          alt={`${title} のアイキャッチ画像`}
          class="w-full rounded-2xl mb-10"
          loading="eager"
        />
      )}

      <!-- Article body -->
      <div class="prose prose-slate prose-lg max-w-none">
        <slot />
      </div>

      <!-- Back link -->
      <div class="mt-16 pt-8 border-t border-[#D8DEE8]">
        <a href="/blog/" class="text-[#0F2557] hover:text-[#F59E0B] font-bold transition-colors">
          ← ブログ一覧に戻る
        </a>
      </div>
    </article>
  </div>
</BaseLayout>
