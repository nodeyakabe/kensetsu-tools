---
interface Props {
  /** 'excel' | 'app' */
  productType: 'excel' | 'app';
}
const { productType } = Astro.props;

const step3 =
  productType === 'excel'
    ? 'ファイルをExcelで開けば、その日から使えます。インストール不要。'
    : 'ダウンロードしたファイルをダブルクリックするだけ。インストール不要。';
---

<div class="w-full max-w-2xl mx-auto my-6 px-2">
  <p class="text-center text-xs font-mono tracking-widest text-[#8FA1C4] mb-5 uppercase">ご購入の流れ</p>
  <ol class="flex flex-col sm:flex-row items-stretch gap-0">
    <!-- Step 1 -->
    <li class="flex-1 flex flex-col items-center text-center relative">
      <div class="w-10 h-10 rounded-full bg-[#0F2557] text-white font-black text-lg flex items-center justify-center flex-shrink-0 z-10">1</div>
      <div class="mt-3 px-4">
        <p class="font-bold text-[#1A2B4A] text-sm leading-snug mb-1">カード決済</p>
        <p class="text-[#5A6B85] text-xs leading-relaxed">「購入する」からStripeの安全な決済画面へ。クレジット・デビットカード対応。</p>
      </div>
      <!-- connector -->
      <div class="hidden sm:block absolute top-5 left-[calc(50%+20px)] right-0 h-px border-t-2 border-dashed border-[#C9D2DF]" aria-hidden="true"></div>
    </li>

    <!-- Step 2 -->
    <li class="flex-1 flex flex-col items-center text-center relative">
      <div class="w-10 h-10 rounded-full bg-[#0F2557] text-white font-black text-lg flex items-center justify-center flex-shrink-0 z-10">2</div>
      <div class="mt-3 px-4">
        <p class="font-bold text-[#1A2B4A] text-sm leading-snug mb-1">メールでお届け</p>
        <p class="text-[#5A6B85] text-xs leading-relaxed">決済完了後すぐに、ご登録のメールアドレスへダウンロードリンクが届きます。</p>
      </div>
      <div class="hidden sm:block absolute top-5 left-[calc(50%+20px)] right-0 h-px border-t-2 border-dashed border-[#C9D2DF]" aria-hidden="true"></div>
    </li>

    <!-- Step 3 -->
    <li class="flex-1 flex flex-col items-center text-center">
      <div class="w-10 h-10 rounded-full bg-[#F59E0B] text-white font-black text-lg flex items-center justify-center flex-shrink-0">3</div>
      <div class="mt-3 px-4">
        <p class="font-bold text-[#1A2B4A] text-sm leading-snug mb-1">その日から使える</p>
        <p class="text-[#5A6B85] text-xs leading-relaxed">{step3}</p>
      </div>
    </li>
  </ol>

  <!-- 注記バッジ -->
  <div class="flex flex-wrap justify-center gap-2 mt-5">
    <span class="bg-[#E4EBF6] text-[#0F2557] text-[11px] font-bold px-3 py-1 rounded-full">月額・追加費用なし</span>
    {productType === 'excel' && <span class="bg-[#E4EBF6] text-[#0F2557] text-[11px] font-bold px-3 py-1 rounded-full">マクロなし</span>}
    <span class="bg-[#E4EBF6] text-[#0F2557] text-[11px] font-bold px-3 py-1 rounded-full">買い切り・永続ライセンス</span>
  </div>
</div>
