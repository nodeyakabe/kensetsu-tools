---
/**
 * CharaDialogue.astro
 * キャラクターの会話・解説コンポーネント
 *
 * 使い方:
 *   <CharaDialogue chara="mikeru" text="工事台帳をつけると確定申告がラクになるにゃ！" />
 *   <CharaDialogue chara="kuroe"  text="一緒に確認してみようにゃ！" direction="right" />
 *
 * direction="left"  → キャラが左、吹き出しが右（デフォルト）
 * direction="right" → キャラが右、吹き出しが左
 */

interface Props {
  chara: 'mikeru' | 'kuroe';
  text: string;
  direction?: 'left' | 'right';
}

const { chara, text, direction = 'left' } = Astro.props;

// mikeru.png / kuroe.png: 512x1476px（個別透過PNG）
// キャラ本体はPNG上部に位置。displayW=100px → scale≈0.195
const charData = {
  mikeru: {
    name: 'ミケル',
    role: '工具マイスター',
    src: '/images/characters/mikeru.png',
    displayW: 100,
    cropH: 140,
    bubbleColor: 'bg-amber-50 border-amber-200',
    nameColor: 'text-amber-700',
  },
  kuroe: {
    name: 'クロエ',
    role: '現場監督サポーター',
    src: '/images/characters/kuroe.png',
    displayW: 100,
    cropH: 140,
    bubbleColor: 'bg-slate-50 border-slate-200',
    nameColor: 'text-slate-600',
  },
} as const;

const c = charData[chara];
const isRight = direction === 'right';
---

<div class:list={['flex gap-4 my-6 items-end', isRight ? 'flex-row-reverse' : '']}>
  <!-- キャラクター -->
  <div class="flex-shrink-0 flex flex-col items-center gap-1">
    <div
      style={`width:${c.displayW}px; height:${c.cropH}px; overflow:hidden; border-radius:8px;`}
    >
      <img
        src={c.src}
        alt={c.name}
        loading="lazy"
        style={`width:${c.displayW}px;`}
      />
    </div>
    <p class:list={['text-xs font-semibold', c.nameColor]}>{c.name}</p>
  </div>

  <!-- 吹き出し -->
  <div
    class:list={[
      'relative border rounded-2xl px-5 py-4 max-w-sm shadow-sm text-sm leading-relaxed text-slate-800',
      c.bubbleColor,
      isRight ? 'rounded-br-none' : 'rounded-bl-none',
    ]}
  >
    {text}
    <!-- 吹き出しの三角 -->
    <span
      class:list={[
        'absolute bottom-3 w-3 h-3 border-b border-l rotate-45',
        c.bubbleColor,
        isRight ? '-right-2 border-r border-t border-b-0 border-l-0' : '-left-2',
      ]}
      style="background:inherit;"
    ></span>
  </div>
</div>
