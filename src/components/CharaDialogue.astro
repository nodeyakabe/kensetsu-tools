---
/**
 * CharaDialogue.astro
 * キャラクターの会話・解説コンポーネント
 *
 * 使い方:
 *   <CharaDialogue chara="mikeru" text="工事台帳をつけると確定申告がラクになるにゃ！" />
 *   <CharaDialogue chara="kuroe"  text="一緒に確認してみようにゃ！" direction="right" />
 *
 * direction="left"  → キャラが左、吹き出しが右（デフォルト）
 * direction="right" → キャラが右、吹き出しが左
 *
 * expression: 現在は 'tati' のみ定義（実際は fileMap でファイルを直接解決）
 *   画像ファイル: uta_product.png（ウタ / chara="mikeru"）、natu_product.png（ナツ / chara="kuroe"）
 *   ※ トップページは uta_tati.png / natu_tati.png を直接参照（このコンポーネントとは別管理）
 */

interface Props {
  chara: 'mikeru' | 'kuroe';
  text: string;
  direction?: 'left' | 'right';
  expression?: 'tati';
}

const { chara, text, direction = 'left' } = Astro.props;

const charData = {
  mikeru: {
    name: 'ウタ',
    defaultExpr: 'tati',
    bubbleColor: 'bg-amber-50 border-amber-200',
    nameColor: 'text-amber-700',
  },
  kuroe: {
    name: 'ナツ',
    defaultExpr: 'tati',
    bubbleColor: 'bg-slate-50 border-slate-200',
    nameColor: 'text-slate-600',
  },
} as const;

const c = charData[chara];
const fileMap: Record<'mikeru' | 'kuroe', string> = { mikeru: 'uta_product', kuroe: 'natu_product' };
const imgSrc = `/images/characters/${fileMap[chara]}.png`;
const isRight = direction === 'right';
---

<div class:list={['flex gap-4 my-6 items-end', isRight ? 'flex-row-reverse' : '']}>
  <!-- キャラクター -->
  <div class="flex-shrink-0 flex flex-col items-center gap-1">
    <img
      src={imgSrc}
      alt={c.name}
      loading="lazy"
      style="width:120px;"
    />
    <p class:list={['text-xs font-semibold', c.nameColor]}>{c.name}</p>
  </div>

  <!-- 吹き出し -->
  <div
    class:list={[
      'relative border rounded-2xl px-6 py-5 max-w-md shadow-sm text-base leading-relaxed text-slate-800',
      c.bubbleColor,
      isRight ? 'rounded-br-none' : 'rounded-bl-none',
    ]}
  >
    {text}
    <!-- 吹き出しの三角 -->
    <span
      class:list={[
        'absolute bottom-3 w-3 h-3 rotate-45',
        isRight ? '-right-2 border-r border-t' : '-left-2 border-b border-l',
        c.bubbleColor,
      ]}
      style="background:inherit;"
    ></span>
  </div>
</div>
