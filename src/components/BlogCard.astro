---
interface Props {
  title: string;
  description: string;
  slug: string;
  publishedAt: Date;
  category?: string;
  tags?: string[];
}

const { title, description, slug, publishedAt, category, tags = [] } = Astro.props;

const formattedDate = publishedAt.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).replace(/\//g, '-');
---

<article class="bg-white border border-[#D8DEE8] rounded-2xl p-6 flex flex-col gap-3 group" style="transition:box-shadow 0.2s ease,transform 0.2s ease;" onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 4px 16px rgba(11,28,66,0.10)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
  <div class="flex items-center gap-3">
    {category && (
      <span class="text-[11px] font-bold bg-[#FDEBC8] text-[#B45309] px-2.5 py-0.5 rounded-full">
        {category}
      </span>
    )}
    <time class="font-mono text-xs text-[#5A6B85]" datetime={publishedAt.toISOString()}>
      {formattedDate}
    </time>
  </div>
  <h2 class="font-bold text-[#1A2B4A] text-base leading-snug group-hover:text-[#0F2557] transition-colors">
    <a href={`/blog/${slug}/`}>{title}</a>
  </h2>
  <p class="text-[#44536E] text-sm leading-relaxed line-clamp-3">{description}</p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {tags.slice(0, 2).map(tag => (
        <span class="text-xs text-[#5A6B85]">#{tag}</span>
      ))}
    </div>
  )}
  <a href={`/blog/${slug}/`} class="text-sm font-bold text-[#F59E0B] hover:text-[#D98908] transition-colors self-start mt-auto">
    読む →
  </a>
</article>
