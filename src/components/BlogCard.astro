---
interface Props {
  title: string;
  description: string;
  slug: string;
  publishedAt: Date;
  category?: string;
  tags?: string[];
}

const { title, description, slug, publishedAt, category, tags = [] } = Astro.props;

const formattedDate = publishedAt.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="bg-white border border-slate-200 rounded-xl p-8 flex flex-col gap-4 hover:shadow-md transition-shadow duration-200 group">
  <div class="flex items-center gap-3">
    {category && (
      <span class="text-xs font-bold bg-primary-50 text-primary-700 border border-primary-200 px-2 py-0.5 rounded-full">
        {category}
      </span>
    )}
    <time class="text-xs text-slate-400" datetime={publishedAt.toISOString()}>
      {formattedDate}
    </time>
  </div>
  <h2 class="font-bold text-slate-900 text-lg leading-snug group-hover:text-primary-700 transition-colors">
    <a href={`/blog/${slug}/`}>{title}</a>
  </h2>
  <p class="text-slate-600 text-sm leading-relaxed line-clamp-3">{description}</p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {tags.slice(0, 2).map(tag => (
        <span class="text-xs text-slate-500">#{tag}</span>
      ))}
    </div>
  )}
  <a href={`/blog/${slug}/`} class="text-sm font-medium text-primary-600 hover:text-primary-800 transition-colors self-start">
    続きを読む →
  </a>
</article>
