---
interface Props {
  title: string;
  desc: string;
}
const { title, desc } = Astro.props;
---
<div class="bg-slate-100 border border-slate-200 rounded-xl p-6 cursor-default">
  <div class="mb-3">
    <span class="inline-block bg-slate-400 text-white text-xs font-bold px-3 py-1 rounded-full">準備中</span>
  </div>
  <h3 class="text-lg font-bold text-slate-600 mb-2">{title}</h3>
  <p class="text-slate-500 text-sm leading-relaxed">{desc}</p>
</div>
