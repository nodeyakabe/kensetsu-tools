---
interface Props {
  title: string;
  desc: string;
}
const { title, desc } = Astro.props;
---
<div class="bg-[#EFF2F7] border-2 border-dashed border-[#D8DEE8] rounded-2xl p-6 cursor-default">
  <div class="mb-3">
    <span class="inline-block bg-[#5A6B85] text-white text-xs font-bold px-3 py-1 rounded-full">準備中</span>
  </div>
  <h3 class="text-base font-bold text-[#44536E] mb-2">{title}</h3>
  <p class="text-[#5A6B85] text-sm leading-relaxed">{desc}</p>
</div>
