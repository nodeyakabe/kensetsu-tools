<script>
  function showAnzenToast() {
    const t = document.getElementById('anzen-buy-toast');
    if (!t) return;
    t.style.display = 'flex';
    setTimeout(() => { t.style.display = 'none'; }, 4000);
  }

  async function handleAnzenBuy(btn: HTMLButtonElement) {
    const allBtns = ['buy-btn-hero','buy-btn-anzen']
      .map(id => document.getElementById(id) as HTMLButtonElement | null)
      .filter(Boolean) as HTMLButtonElement[];
    allBtns.forEach(b => { b.disabled = true; });
    const orig = btn.textContent;
    btn.textContent = '読み込み中…';
    try {
      const res = await fetch('/api/create-checkout-anzen', { method: 'POST' });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      if (!data?.url) throw new Error('no url');
      window.location.href = data.url;
    } catch {
      showAnzenToast();
      allBtns.forEach(b => { b.disabled = false; });
      btn.textContent = orig ?? '';
    }
  }

  async function handleSetBuy(btn: HTMLButtonElement) {
    const orig = btn.textContent;
    btn.disabled = true;
    btn.textContent = '読み込み中…';
    try {
      const res = await fetch('/api/create-checkout-set', { method: 'POST' });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      if (!data?.url) throw new Error('no url');
      window.location.href = data.url;
    } catch {
      showAnzenToast();
      btn.disabled = false;
      btn.textContent = orig ?? '';
    }
  }

  function initAnzenBuyButtons() {
    ['buy-btn-hero','buy-btn-anzen'].forEach(id => {
      const b = document.getElementById(id) as HTMLButtonElement | null;
      if (!b || b.dataset.buyInit) return;
      b.dataset.buyInit = '1';
      b.addEventListener('click', () => handleAnzenBuy(b!));
    });
    const setBtn = document.getElementById('buy-btn-set') as HTMLButtonElement | null;
    if (setBtn && !setBtn.dataset.buyInit) {
      setBtn.dataset.buyInit = '1';
      setBtn.addEventListener('click', () => handleSetBuy(setBtn));
    }
  }

  initAnzenBuyButtons();
  document.addEventListener('astro:page-load', initAnzenBuyButtons);

  // ===== 安全台帳ページ アニメーション =====
  var _azObservers: IntersectionObserver[] = (window as any)._azObservers || [];

  function initAzAnimations() {
    _azObservers.forEach(function(o) { o.disconnect(); });
    _azObservers = [];

    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced || !('IntersectionObserver' in window)) return;

    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('az-visible');
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08 });

    document.querySelectorAll('.az-reveal, .az-reveal-from-left, .az-reveal-from-right').forEach(function(el) {
      obs.observe(el);
    });
    _azObservers.push(obs);
    (window as any)._azObservers = _azObservers;
  }

  initAzAnimations();
  document.addEventListener('astro:page-load', initAzAnimations);

  // ===== ライトボックス =====
  function initAzLightbox() {
    const lb       = document.getElementById('az-lightbox');
    const lbImg    = document.getElementById('az-lb-img') as HTMLImageElement | null;
    const closeBtn = document.getElementById('az-lb-close');
    const mainEl   = document.querySelector('main');
    if (!lb || !lbImg || !closeBtn) return;

    // 前回のリスナーを AbortController でまとめて解除
    const prevAc = (window as any).__azLbAbort;
    if (prevAc) prevAc.abort();
    const ac = new AbortController();
    (window as any).__azLbAbort = ac;
    const sig = { signal: ac.signal };

    // 初期状態リセット
    document.body.style.overflow = '';
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    mainEl?.removeAttribute('aria-hidden');

    let lastFocused: HTMLElement | null = null;
    const preventTouch = (e: Event) => e.preventDefault();

    const open = (src: string, alt: string) => {
      lastFocused = document.activeElement as HTMLElement;
      lbImg.src = src; lbImg.alt = alt || '';
      lb.classList.remove('hidden'); lb.classList.add('flex');
      document.body.style.overflow = 'hidden';
      lb.addEventListener('touchmove', preventTouch, { passive: false, signal: ac.signal });
      mainEl?.setAttribute('aria-hidden', 'true');
      closeBtn.focus();
    };
    const close = () => {
      document.body.style.overflow = '';
      lb.removeEventListener('touchmove', preventTouch);
      lb.classList.add('hidden'); lb.classList.remove('flex');
      lbImg.src = '';
      mainEl?.removeAttribute('aria-hidden');
      lastFocused?.focus();
    };

    lb.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Tab') { e.preventDefault(); closeBtn.focus(); } }, sig);
    document.querySelectorAll<HTMLElement>('.gallery-wrapper').forEach((wrapper) => {
      const img = wrapper.querySelector('img');
      const handler = () => { if (img) open(img.currentSrc || img.src, img.alt); };
      wrapper.addEventListener('click', handler, sig);
      wrapper.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); handler(); } }, sig);
    });
    lb.addEventListener('click', (e: MouseEvent) => { if (e.target === lb) close(); }, sig);
    closeBtn.addEventListener('click', close, sig);
    document.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Escape') close(); }, sig);
  }

  initAzLightbox();
  document.addEventListener('astro:page-load', initAzLightbox);
</script>

