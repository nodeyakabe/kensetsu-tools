---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CharaDialogue from '@/components/CharaDialogue.astro';
import { PRODUCT as KOJI_PRODUCT } from '@/data/product';

const siteUrl = (import.meta.env.SITE ?? 'https://kensetsu-tools.com').replace(/\/$/, '');
const priceValidUntil = `${new Date().getFullYear() + 1}-12-31`;

const PRODUCT = {
  name: 'シンプル安全台帳',
  price: 9800,
  priceSet: 13800,
  currency: 'JPY',
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": PRODUCT.name,
  "description": "作業員・資格・車両の期限を自動管理。作業員名簿など安全書類もPDF出力。完全オフライン・買い切り・月額なし。",
  "brand": { "@type": "Brand", "name": "建設業ツール工房" },
  "url": `${siteUrl}/products/anzen-daicho/`,
  "image": `${siteUrl}/og/anzen-daicho.png`,
  "offers": {
    "@type": "Offer",
    "price": String(PRODUCT.price),
    "priceCurrency": PRODUCT.currency,
    "availability": "https://schema.org/InStock",
    "url": `${siteUrl}/products/anzen-daicho/`,
    "priceValidUntil": priceValidUntil,
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム",        "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "ツール・商品",  "item": `${siteUrl}/products/` },
    { "@type": "ListItem", "position": 3, "name": PRODUCT.name,    "item": `${siteUrl}/products/anzen-daicho/` },
  ],
};

const features = [
  { title: '期限管理ダッシュボード',       desc: '起動直後に「誰の何がいつ切れる」が一画面で分かる。赤・橙・黄で色分け表示。' },
  { title: '作業員・資格管理',             desc: '作業員を登録し、保有資格を記録。健康診断や免許など期限のあるものは自動アラートで管理。' },
  { title: '車両管理',                     desc: '車検・自賠責・任意保険の期限を登録。期限切れ直前に自動で警告表示。' },
  { title: '現場管理',                     desc: '現場ごとに入場作業員・持込車両を選択。チームの状況をひとまとめに。' },
  { title: '作業員名簿 PDF出力',           desc: '全建統一様式の記載項目に準拠した作業員名簿（独自様式）をワンクリックでPDF生成。健診・免許など期限切れがある人は赤くハイライト。' },
  { title: '工事・通勤用車両届 PDF出力',   desc: '工事・通勤用車両届を車両ごとにPDF生成。車検・保険切れ車両は赤く警告表示。' },
];

const problems = [
  { title: '資格・免許の期限管理が大変',     body: '玉掛け・フォーク・各種講習。誰がいつまでか、把握しきれない。' },
  { title: '車検・保険をうっかり切らす',     body: '複数の車両があると、車検や任意保険の更新を見落としがち。' },
  { title: '健康診断の時期が分からない',     body: '作業員ごとの受診時期。気づいたら1年以上空いていることも。' },
  { title: '安全書類づくりが毎回手間',       body: '現場ごとに作業員名簿。同じ情報を、何度も書き写している。' },
  { title: 'クラウドへの個人情報送信が不安', body: 'クラウドサービスに作業員の個人情報・免許証番号を上げるのが気になる。' },
];

const comparisonRows = [
  { label: '価格',             vals: ['無料（手間は自分持ち）', '月額3,000円〜', '年約5,000円〜＋初期費用（元請負担の場合あり）', `¥${PRODUCT.price.toLocaleString()}（買い切り）`] },
  { label: 'ネット接続',       vals: ['不要', '必要', '必要（グリーンサイト登録）', '完全不要'] },
  { label: '個人情報の扱い',   vals: ['自己管理', 'クラウド保存', 'クラウド保存', 'PC内のみ（外部送信なし）'] },
  { label: '期限自動アラート', vals: ['× 自分で管理', '○', '○', '◎ 起動直後に一覧表示'] },
  { label: 'PDF帳票出力',      vals: ['× テンプレなし', '○', '○（元請指定様式）', '○（作業員名簿・車両届）'] },
  { label: 'サポート',         vals: ['なし', 'あり', 'あり', 'なし'] },
];
---

<BaseLayout
  title="シンプル安全台帳｜資格・車検期限管理と作業員名簿PDF出力｜買い切り¥9,800"
  description="作業員の資格・健康診断、車両の車検・保険を期限管理。作業員名簿・工事・通勤用車両届をPDFで一発出力。完全オフライン・データはPC内のみ・月額なし・買い切り¥9,800。建設業の小規模下請向け。"
  ogImage="/og/anzen-daicho.png"
  ogType="product"
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <style is:global>
    /* ===== 安全台帳ページ アニメーション（上昇フェード） ===== */
    @media (prefers-reduced-motion: no-preference) {
      /* 通常：下から上昇しながらフェードイン（工事台帳のscaleとは逆） */
      .az-reveal {
        opacity: 0;
        transform: translateY(32px);
        transition: opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
                    transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
      }
      .az-reveal.az-visible {
        opacity: 1;
        transform: translateY(0);
      }
      /* ヒーロー左カラム：右からスライドイン */
      .az-reveal-from-left {
        opacity: 0;
        transform: translateX(-28px);
        transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                    transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
      }
      .az-reveal-from-left.az-visible {
        opacity: 1;
        transform: translateX(0);
      }
      /* ヒーロー右カラム：左からスライドイン */
      .az-reveal-from-right {
        opacity: 0;
        transform: translateX(28px);
        transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                    transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
      }
      .az-reveal-from-right.az-visible {
        opacity: 1;
        transform: translateX(0);
      }
      /* カードスタガー遅延 */
      .az-stagger > .az-reveal:nth-child(1) { transition-delay:   0ms; }
      .az-stagger > .az-reveal:nth-child(2) { transition-delay:  70ms; }
      .az-stagger > .az-reveal:nth-child(3) { transition-delay: 140ms; }
      .az-stagger > .az-reveal:nth-child(4) { transition-delay: 210ms; }
      .az-stagger > .az-reveal:nth-child(5) { transition-delay: 280ms; }
      .az-stagger > .az-reveal:nth-child(6) { transition-delay: 350ms; }
    }
    .az-mono { font-family: 'JetBrains Mono', monospace; }
    .az-pill {
      display: inline-block;
      border: 1.5px solid #0F2557;
      color: #0F2557;
      font-size: 12px;
      font-weight: 700;
      padding: 7px 26px;
      border-radius: 999px;
    }
    /* グリッド */
    .az-hero-grid    { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; }
    .az-prob-grid    { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
    .az-feat-grid    { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
    .az-screen-grid  { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }
    .az-price-grid   { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; align-items: stretch; }
    .az-chara-grid   { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
    /* カード */
    .az-prob-card { background: #FFFFFF; border-radius: 20px; padding: 28px 24px; display: flex; flex-direction: column; gap: 10px; }
    .az-feat-card { background: #F3F6FB; border-radius: 20px; padding: 28px 24px; display: flex; flex-direction: column; gap: 10px; }
    /* セクション遷移 */
    .az-wave { border-radius: 80px 80px 0 0; }
    .az-wave-pull { margin-top: -40px; }
    /* 価格カード等高 */
    .az-price-card { display: flex; flex-direction: column; }
    .az-price-list { flex: 1; }
    /* ライトボックス ホバーヒント */
    .gallery-wrapper:hover .az-lb-overlay-hint { background: rgba(15,37,87,0.18) !important; }
    .gallery-wrapper:hover .az-lb-overlay-hint span { opacity: 1 !important; }
    /* レスポンシブ */
    @media (max-width: 767px) {
      .az-hero-grid   { grid-template-columns: 1fr; gap: 28px; }
      .az-prob-grid   { grid-template-columns: 1fr; }
      .az-feat-grid   { grid-template-columns: 1fr; }
      .az-screen-grid { grid-template-columns: 1fr; }
      .az-price-grid  { grid-template-columns: 1fr; }
      .az-chara-grid  { grid-template-columns: 1fr; }
    }
    @media (min-width: 768px) and (max-width: 1023px) {
      .az-prob-grid { grid-template-columns: repeat(2, 1fr); }
      .az-feat-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>

  <!-- パンくず -->
  <div class="w-full px-4 sm:px-6 lg:px-10 py-3 bg-white border-b border-slate-100">
    <nav class="text-sm text-slate-500" aria-label="パンくずリスト">
      <a href="/" class="hover:text-primary-600 transition-colors">ホーム</a>
      <span class="mx-2">/</span>
      <a href="/products/" class="hover:text-primary-600 transition-colors">ツール・商品</a>
      <span class="mx-2">/</span>
      <span class="text-slate-700">シンプル安全台帳</span>
    </nav>
  </div>

  <!-- S1: ヒーロー -->
  <section style="background: #FFFFFF; position: relative; overflow: hidden;">
    <!-- 装飾 -->
    <div style="position: absolute; top: -280px; right: -280px; width: 760px; height: 760px; border: 110px solid #E4F1EA; border-radius: 50%; pointer-events: none;"></div>
    <div style="position: absolute; bottom: -60px; left: -80px; width: 280px; height: 280px; background: #F1F7F3; border-radius: 50%; pointer-events: none;"></div>

    <div class="container-base" style="padding-top: 56px; padding-bottom: 88px; position: relative;">
      <div class="az-hero-grid">

        <!-- 左：スクリーンショット -->
        <div class="az-reveal-from-left" style="position: relative;">
          <div style="position: absolute; top: -16px; left: -16px; width: 180px; height: 180px; background: #E4F1EA; border-radius: 50%; z-index: 0;"></div>
          <div style="position: absolute; bottom: -14px; right: -14px; width: 80px; height: 80px; background: #CDE6D8; border-radius: 50%; z-index: 0;"></div>
          <div style="position: relative; z-index: 1; background: #FFFFFF; border: 1.5px solid #D8DEE8; border-radius: 18px; overflow: hidden; box-shadow: 0 22px 52px rgba(15,37,87,0.14);">
            <div style="background: #F4F7F5; padding: 10px 16px; display: flex; align-items: center; gap: 8px; border-bottom: 1px solid #E3E8F0;">
              <span style="font-size: 12.5px; font-weight: 900; color: #0F2557;">期限管理ダッシュボード</span>
              <span class="az-mono" style="margin-left: auto; font-size: 10.5px; color: #8FA1C4;">ANZEN-DAICHO</span>
            </div>
            <!-- サイドバーを除いてメインコンテンツ部分をズームイン表示 -->
            <div style="overflow: hidden; height: 300px;">
              <img
                src="/images/screens/anzen/screen_dashboard.png"
                alt="期限管理ダッシュボード画面"
                style="width: 130%; max-width: none; margin-left: -22%; height: auto; display: block;"
                loading="eager"
              />
            </div>
          </div>
        </div>

        <!-- 右：テキスト -->
        <div class="az-reveal-from-right" style="display: flex; flex-direction: column; gap: 22px;">
          <span class="az-mono" style="font-size: 11.5px; letter-spacing: 0.14em; color: #44536E;">KENSETSU-TOOLS</span>
          <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            <span style="background: #E4F1EA; color: #11512F; font-size: 12px; font-weight: 700; padding: 5px 16px; border-radius: 999px;">発売中</span>
            <span style="border: 1px solid #5A6B85; color: #5A6B85; font-size: 12px; font-weight: 700; padding: 4px 14px; border-radius: 999px;">第2弾</span>
            <span style="border: 1px solid #5A6B85; color: #5A6B85; font-size: 12px; font-weight: 700; padding: 4px 14px; border-radius: 999px;">小規模建設業向け</span>
          </div>
          <h1 style="margin: 0; font-size: 36px; font-weight: 900; line-height: 1.65; color: #1A2B4A; letter-spacing: 0.04em;">
            資格と車両の期限を、<br>
            ひと目で、<span style="color: #11512F;">もう切らさない。</span>
          </h1>
          <p style="margin: 0; font-size: 14.5px; line-height: 2.1; color: #44536E; max-width: 500px;">
            作業員の資格・健康診断、車両の車検・保険といった「期限もの」をまとめて管理し、安全書類づくりまでつなげるツールです。完全オフライン・買い切り・月額なし。
          </p>
          <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            {['✓ 期限アラート', '✓ 作業員名簿PDF', '✓ 完全オフライン', '✓ 買い切り'].map(chip => (
              <span style="background: #E4F1EA; border-radius: 999px; padding: 6px 16px; font-size: 12.5px; font-weight: 700; color: #11512F;">{chip}</span>
            ))}
          </div>
          <div style="display: flex; align-items: center; gap: 14px; flex-wrap: wrap;">
            <button
              id="buy-btn-hero"
              type="button"
              class="bg-accent-500 hover:bg-accent-600 text-white font-bold transition-colors"
              style="font-size: 15px; padding: 15px 34px; border-radius: 999px; border: none; cursor: pointer;"
            >
              今すぐ購入する →
            </button>
            <div style="display: flex; align-items: baseline; gap: 4px;">
              <span style="font-size: 26px; font-weight: 900; color: #0F2557;">¥{PRODUCT.price.toLocaleString()}</span>
              <span style="font-size: 12px; color: #5A6B85;">税込・買い切り</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- S2: 悩み -->
  <section class="az-wave" style="background: #E4EBF6; position: relative; overflow: hidden;">
    <div style="position: absolute; top: -200px; right: -240px; width: 680px; height: 680px; background: #EDF2F9; border-radius: 50%; pointer-events: none;"></div>
    <div class="container-base az-reveal" style="padding-top: 80px; padding-bottom: 72px; position: relative; display: flex; flex-direction: column; gap: 36px;">
      <div style="display: flex; flex-direction: column; align-items: center; gap: 12px; text-align: center;">
        <span class="az-pill">PROBLEM — こんな悩みありませんか？</span>
        <h2 style="margin: 0; font-size: 30px; font-weight: 900; color: #0F2557; letter-spacing: 0.04em;">「期限切れ」と「安全書類」が、頭から離れない。</h2>
      </div>
      <div class="az-prob-grid az-stagger">
        {problems.map(item => (
          <div class="az-prob-card az-reveal">
            <div style="width: 38px; height: 38px; background: #FDEBC8; border-radius: 50%; color: #B45309; font-weight: 900; font-size: 16px; display: flex; align-items: center; justify-content: center; flex: none;">!</div>
            <div style="font-size: 15px; font-weight: 900; color: #0F2557;">{item.title}</div>
            <div style="font-size: 13.5px; line-height: 1.95; color: #5A6B85;">{item.body}</div>
          </div>
        ))}
        <div class="az-reveal" style="background: #11512F; border-radius: 20px; padding: 28px 24px; display: flex; flex-direction: column; gap: 10px; justify-content: center;">
          <div style="font-size: 15.5px; font-weight: 900; color: #FFFFFF; line-height: 1.75;">その「期限」と「名簿」、<br>ひとつの台帳にまとめます。</div>
          <div style="font-size: 13px; line-height: 1.9; color: #BFE8D2;">入れておくのは、人と資格と車両だけ。</div>
        </div>
      </div>
    </div>
  </section>

  <!-- S3: 機能 -->
  <section class="az-wave az-wave-pull" style="background: #FFFFFF; position: relative;">
    <div class="container-base az-reveal" style="padding-top: 80px; padding-bottom: 64px; display: flex; flex-direction: column; gap: 36px;">
      <div style="display: flex; flex-direction: column; align-items: center; gap: 12px; text-align: center;">
        <span class="az-pill">FUNCTION — 主な機能</span>
        <h2 style="margin: 0; font-size: 30px; font-weight: 900; color: #0F2557; letter-spacing: 0.04em;">必要な機能だけを、ぜんぶ。</h2>
      </div>
      <div class="az-feat-grid az-stagger">
        {features.map((f, i) => (
          <div class="az-feat-card az-reveal">
            <span class="az-mono" style="font-size: 12px; color: #F59E0B; font-weight: 500;">{String(i + 1).padStart(2, '0')}</span>
            <div style="font-size: 15.5px; font-weight: 900; color: #0F2557;">{f.title}</div>
            <div style="font-size: 13.5px; line-height: 1.95; color: #5A6B85;">{f.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- S4: 比較 + キャラ -->
  <section class="az-wave" style="background: #E4EBF6; position: relative; overflow: hidden;">
    <div style="position: absolute; bottom: -180px; left: -160px; width: 520px; height: 520px; background: #EDF2F9; border-radius: 50%; pointer-events: none;"></div>
    <div class="container-base az-reveal" style="padding-top: 80px; padding-bottom: 72px; position: relative; display: flex; flex-direction: column; gap: 40px;">

      <!-- 比較見出し -->
      <div style="display: flex; flex-direction: column; align-items: center; gap: 12px; text-align: center;">
        <span class="az-pill">COMPARISON — 比較</span>
        <h2 style="margin: 0; font-size: 30px; font-weight: 900; color: #0F2557; letter-spacing: 0.04em;">他のツールと比べてみると</h2>
        <p style="margin: 0; font-size: 13.5px; color: #5A6B85;">用途が違うだけで、どれも正解です。本品が合うかどうか確認してください。</p>
      </div>

      <!-- モバイル比較カード -->
      <div class="md:hidden space-y-2">
        {comparisonRows.map(row => (
          <div style="border-radius: 14px; border: 1px solid #D8DEE8; overflow: hidden;">
            <div style="background: #DDE4F0; padding: 10px 16px; font-size: 13.5px; font-weight: 700; color: #0F2557;">{row.label}</div>
            <div style="padding: 14px 16px; background: #FFFFFF; display: flex; flex-direction: column; gap: 10px;">
              <div style="display: flex; align-items: flex-start; gap: 8px; background: #FFF9EF; border-left: 3px solid #F59E0B; border-radius: 6px; padding: 10px 12px;">
                <span style="font-size: 11.5px; font-weight: 700; color: #F59E0B; flex: none; padding-top: 2px;">本品</span>
                <span style="font-size: 13.5px; font-weight: 700; color: #0F2557;">{row.vals[3]}</span>
              </div>
              <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; font-size: 11.5px; text-align: center; color: #5A6B85;">
                <div><p style="margin: 0 0 4px; font-weight: 600; color: #8FA1C4;">Excel手動</p><p style="margin: 0;">{row.vals[0]}</p></div>
                <div><p style="margin: 0 0 4px; font-weight: 600; color: #8FA1C4;">月額ソフト</p><p style="margin: 0;">{row.vals[1]}</p></div>
                <div><p style="margin: 0 0 4px; font-weight: 600; color: #8FA1C4;">グリーンサイト</p><p style="margin: 0;">{row.vals[2]}</p></div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- デスクトップ比較テーブル -->
      <div class="hidden md:block overflow-x-auto">
        <div style="border: 1px solid #C8D3E8; border-radius: 16px; overflow: hidden;">
          <table style="width: 100%; font-size: 13.5px; border-collapse: collapse;">
            <thead>
              <tr>
                <th style="text-align: left; padding: 14px 20px; background: #DDE4F0; color: #5A6B85; font-weight: 700; border-bottom: 2px solid #0F2557; width: 160px;">比較項目</th>
                <th style="padding: 14px 14px; background: #DDE4F0; color: #5A6B85; font-weight: 700; border-bottom: 2px solid #0F2557; text-align: center;">Excel手動管理</th>
                <th style="padding: 14px 14px; background: #DDE4F0; color: #5A6B85; font-weight: 700; border-bottom: 2px solid #0F2557; text-align: center;">月額型クラウドソフト</th>
                <th style="padding: 14px 14px; background: #DDE4F0; color: #5A6B85; font-weight: 700; border-bottom: 2px solid #0F2557; text-align: center;">グリーンサイト<br/><span style="font-size: 11px; font-weight: 400;">（クラウド）</span></th>
                <th style="padding: 14px 14px; background: #0F2557; color: #FFFFFF; font-weight: 900; border-bottom: 2px solid #0F2557; text-align: center;">本品</th>
              </tr>
            </thead>
