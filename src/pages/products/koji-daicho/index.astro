---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CharaDialogue from '@/components/CharaDialogue.astro';
import { PRODUCT } from '@/data/product';

const siteUrl = (import.meta.env.SITE ?? 'https://kensetsu-tools.com').replace(/\/$/, '');
const priceValidUntil = `${new Date().getFullYear() + 1}-12-31`;

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": PRODUCT.name,
  "description": "確定申告がラクになる、Excelだけで動く工事管理ツール。収支管理に特化・マクロ不使用・買い切り。",
  "brand": { "@type": "Brand", "name": "建設業ツール工房" },
  "url": `${siteUrl}/products/koji-daicho/`,
  "image": `${siteUrl}/og/koji-daicho.png`,
  "offers": {
    "@type": "Offer",
    "price": String(PRODUCT.price),
    "priceCurrency": PRODUCT.currency,
    "availability": "https://schema.org/InStock",
    "url": `${siteUrl}/products/koji-daicho/`,
    "priceValidUntil": priceValidUntil
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "ツール・商品", "item": `${siteUrl}/products/` },
    { "@type": "ListItem", "position": 3, "name": PRODUCT.name, "item": `${siteUrl}/products/koji-daicho/` },
  ],
};

const features = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>`,
    title: '工事登録',
    desc: '工事名・施主・金額など5項目だけ。迷わず使える設計。',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="12" y2="14"/></svg>`,
    title: '原価入力',
    desc: '材料費・外注費・労務費を種別に分けて記録・集計。',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
    title: '月次・年次サマリー',
    desc: '売上・原価・利益を自動集計。確定申告の準備に直結。',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1-2-1z"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="16" y2="14"/></svg>`,
    title: 'インボイス番号管理',
    desc: '取引先のインボイス番号を一覧管理・対象別に集計。',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>`,
    title: '改正建設業法 入力支援',
    desc: '原価割れの参考表示や労務費の入力支援。※法令適合性は保証外',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><polyline points="9 15 12 18 15 15"/></svg>`,
    title: 'CSV出力',
    desc: '会計ソフトや税理士提出用に、CSV形式で書き出せます。',
  },
];

const comparisonRows = [
  { label: '価格',           vals: ['無料', '¥8,800前後（買い切り）', '月額4,000円〜', `¥${PRODUCT.price.toLocaleString()}（買い切り）`] },
  { label: 'マクロ',         vals: ['ものによる', 'あり（警告が出ることも）', '—（Web/アプリ）', 'なし（警告ゼロ）'] },
  { label: '確定申告の収支管理', vals: ['△ 自分で作り込む', '○', '○', '◎ これに特化'] },
  { label: '入力ミス防止',   vals: ['× 基本なし', '△', '○', '○（色で警告）'] },
  { label: '主な対象',       vals: ['Excelが得意な方', '中小〜の事業者', '法人・複数人の現場', '一人親方・ITが苦手な方'] },
  { label: 'サポート',       vals: ['なし', 'あり', 'あり', '60日メールサポート'] },
];

---

<BaseLayout
  title="シンプル工事台帳 ライト版｜一人親方の確定申告用Excel工事台帳"
  description="一人親方・個人事業主向けのExcel工事台帳。工事ごとの収支を自動集計し確定申告がラクになります。インボイス番号管理・CSV出力対応。マクロ不使用・買い切り¥5,980。60日メールサポート付き。"
  ogImage="/og/koji-daicho.png"
  ogType="product"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- パンくず -->
  <div class="container-base py-3">
    <nav class="text-sm text-slate-500" aria-label="パンくずリスト">
      <a href="/" class="hover:text-primary-600 transition-colors">ホーム</a>
      <span class="mx-2">/</span>
      <a href="/products/" class="hover:text-primary-600 transition-colors">ツール・商品</a>
      <span class="mx-2">/</span>
      <span class="text-slate-700">シンプル工事台帳 ライト版</span>
    </nav>
  </div>

  <!-- S1：ヒーロー -->
  <section class="bg-slate-50 py-12 md:py-16">
    <div class="container-base text-center max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-primary-900 mb-4">
        シンプル工事台帳 ライト版
      </h1>
      <p class="text-sm text-slate-500 mb-2">個人事業主・一人親方（暦年決算）向け</p>
      <p class="text-xl md:text-2xl text-slate-600 mb-4 leading-relaxed">
        確定申告がラクになる、<br>
        Excelだけで動く工事管理ツール。
      </p>
      <p class="text-3xl font-semibold text-accent-500 mb-6">¥{PRODUCT.price.toLocaleString()}</p>
      <button
        id="buy-btn-hero"
        type="button"
        class="inline-block bg-accent-500 hover:bg-accent-600 text-white font-bold px-8 py-4 rounded-xl text-lg transition-colors shadow-md"
      >
        今すぐ購入する →
      </button>
      <!-- 信頼チップ -->
      <div class="flex flex-wrap justify-center gap-2 mt-5">
        {['買い切り・月額なし', 'マクロなし', 'インストール不要', '3分で使い始め', '60日メールサポート'].map(chip => (
          <span class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-medium bg-primary-50 text-primary-800 border border-primary-200">
            <span aria-hidden="true">✓</span>
            {chip}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- S2：悩み -->
  <section class="py-16 bg-white">
    <div class="container-base max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold text-primary-900 mb-8 text-center">こんな悩みありませんか？</h2>
      <ul class="space-y-4">
        {[
          '工事台帳の管理が、紙やExcel自作で面倒',
          '確定申告の準備が、毎年大変',
          '既存の業務ソフトはサブスクで毎月料金がかかる',
          'インボイス制度や改正建設業法への対応が不安',
          'ITに詳しくないけど、何か始めたい',
        ].map(item => (
          <li class="flex items-start gap-4 text-lg text-slate-700">
            <span class="text-red-400 font-black text-xl flex-shrink-0 mt-0.5" aria-hidden="true">!</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- S3：こう変わる -->
  <section class="py-16 bg-slate-50">
    <div class="container-base">
      <h2 class="text-3xl font-bold text-primary-900 mb-10 text-center">シンプル工事台帳なら、こう変わる</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {[
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>`,
            title: 'シンプル',
            desc: '5項目を入力するだけで、工事台帳が完成します。迷わず使える設計です。',
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>`,
            title: '安心',
            desc: 'マクロを使わないExcelファイル。怪しい警告が出ません。',
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
            title: '経済的',
            desc: '¥5,980の買い切り。月額料金は一切ありません。',
          },
        ].map(card => (
          <div class="bg-white border border-slate-200 rounded-xl p-8 text-center">
            <div class="text-accent-500 flex justify-center mb-4" set:html={card.icon} />
            <h3 class="text-xl font-bold text-primary-900 mb-3">{card.title}</h3>
            <p class="text-slate-600 leading-relaxed text-sm">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- S4：機能（3列グリッド） -->
  <section class="py-16 bg-white">
    <div class="container-base max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-primary-900 mb-8 text-center">主な機能</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {features.map(f => (
          <div class="flex items-start gap-3 bg-white border border-slate-200 rounded-xl p-5 shadow-sm">
            <div class="text-accent-500 flex-shrink-0" set:html={f.icon} />
            <div>
              <h3 class="text-base font-bold text-primary-900 mb-1">{f.title}</h3>
              <p class="text-slate-600 text-sm leading-relaxed">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- S4c：他社比較（本品列オレンジ帯ハイライト） -->
  <section class="py-16 bg-white">
    <div class="container-base max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-primary-900 mb-4 text-center">他のツールと比べてみると</h2>
      <p class="text-slate-500 text-center mb-10 text-sm">用途が違うだけで、どれも正解です。本品が合うかどうか確認してください。</p>
      <!-- モバイル比較カード（md未満） -->
      <div class="md:hidden space-y-2 mb-6">
        {comparisonRows.map(row => (
          <div class="rounded-xl border border-slate-200 overflow-hidden">
            <div class="bg-slate-100 px-4 py-2.5 text-sm font-semibold text-slate-700">{row.label}</div>
            <div class="p-4 space-y-3">
              <div class="flex items-start gap-2 rounded-lg px-3 py-2.5" style="background:#FFF7ED; border-left: 3px solid #F59E0B;">
                <span class="text-xs font-bold text-accent-600 flex-shrink-0 pt-0.5">本品</span>
                <span class="text-sm font-semibold text-primary-900">{row.vals[3]}</span>
              </div>
              <div class="grid grid-cols-3 gap-2 text-xs text-center text-slate-500">
                <div>
                  <p class="font-medium text-slate-400 mb-1 leading-tight">無料テンプレ</p>
                  <p class="leading-tight">{row.vals[0]}</p>
                </div>
                <div>
                  <p class="font-medium text-slate-400 mb-1 leading-tight">市販台帳</p>
                  <p class="leading-tight">{row.vals[1]}</p>
                </div>
                <div>
                  <p class="font-medium text-slate-400 mb-1 leading-tight">クラウド型</p>
                  <p class="leading-tight">{row.vals[2]}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- デスクトップ比較テーブル（md以上） -->
      <div class="hidden md:block overflow-x-auto -mx-4 px-4">
        <table class="w-full text-sm border-collapse min-w-[640px]">
          <thead>
            <tr>
              <th scope="col" class="text-left px-4 py-3 bg-slate-100 text-slate-600 font-medium rounded-tl-xl border-b border-slate-200 w-36">比較項目</th>
              <th scope="col" class="px-4 py-3 bg-slate-100 text-slate-600 font-medium border-b border-slate-200 text-center">無料Excelテンプレ</th>
              <th scope="col" class="px-4 py-3 bg-slate-100 text-slate-600 font-medium border-b border-slate-200 text-center">市販の工事台帳<br class="hidden sm:inline"/><span class="text-xs font-normal">（日本法令 等）</span></th>
              <th scope="col" class="px-4 py-3 bg-slate-100 text-slate-600 font-medium border-b border-slate-200 text-center">クラウド型<br class="hidden sm:inline"/><span class="text-xs font-normal">（月額サービス）</span></th>
              <th scope="col" class="px-4 py-3 font-bold text-center text-white rounded-tr-xl" style="background: #F59E0B; border: 2px solid #F59E0B;">本品<br class="hidden sm:inline"/><span class="text-xs font-normal opacity-80">ライト版</span></th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50'}>
                <td class="px-4 py-3 text-slate-500 font-medium border-b border-slate-100">{row.label}</td>
                {row.vals.map((v, j) => (
                  <td
                    class={`px-4 py-3 text-center ${j === 3 ? 'text-primary-900 font-semibold' : 'text-slate-600 border-b border-slate-100'}`}
                    style={j === 3 ? `background: #FFF7ED; border-left: 2px solid #F59E0B; border-right: 2px solid #F59E0B; border-bottom: ${i === comparisonRows.length - 1 ? '2px solid #F59E0B' : '1px solid #FED7AA'};` : ''}
                  >
                    {v}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-slate-400 text-center mt-4">※ 価格・機能は2026年時点の各社公開情報に基づく参考比較です。</p>
    </div>
  </section>


  <!-- S4d：キャラクターコメント（比較表の補足・ウタ→ナツの順） -->
  <section class="pt-4 pb-16 bg-white">
    <div class="container-base max-w-2xl mx-auto">
      <CharaDialogue
        chara="mikeru"
        text="いろんな機能があっても、どうせ使わないんだよなぁ。あれこれ多いと、かえってどこを触ればいいか分からなくなる。"
        direction="left"
        expression="tati"
      />
      <CharaDialogue
        chara="kuroe"
        text="サブスクはずっと払い続けると、合計でけっこうな額になるのだ。買い切りなら一度きり。そのほうが安心できるのだ。"
        direction="right"
        expression="tati"
      />
    </div>
  </section>

  <!-- S5：実際の画面（5枚スクリーンショット） -->
  <section class="py-16 bg-slate-50">
    <div class="container-base max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-primary-900 mb-4 text-center">画面イメージ</h2>
      <p class="text-slate-500 text-center mb-2">実際のExcelファイルの画面です。</p>
      <p class="text-sm text-slate-400 text-center mb-10">画像をクリックすると拡大できます</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

        <figure class="rounded-xl border-2 border-slate-300 bg-white overflow-hidden shadow-sm">
          <div class="aspect-[4/3] bg-white flex items-center justify-center p-3 cursor-zoom-in gallery-wrapper"
               role="button" tabindex="0" aria-label="ホーム画面を拡大">
            <img src="/images/screens/screen_home.png" alt="シンプル工事台帳 ホーム画面"
                 class="max-h-full max-w-full object-contain pointer-events-none" loading="lazy" />
          </div>
          <figcaption class="border-t border-slate-100 px-4 py-3 text-center">
            <p class="font-medium text-slate-800">ホーム</p>
            <p class="text-sm text-slate-500">1枚のメニューから全機能にアクセス</p>
          </figcaption>
        </figure>

        <figure class="rounded-xl border-2 border-slate-300 bg-white overflow-hidden shadow-sm">
          <div class="aspect-[4/3] bg-white flex items-center justify-center p-3 cursor-zoom-in gallery-wrapper"
               role="button" tabindex="0" aria-label="年次サマリー画面を拡大">
            <img src="/images/screens/screen_nenjisummary.png" alt="シンプル工事台帳 年次サマリー画面"
                 class="max-h-full max-w-full object-contain pointer-events-none" loading="lazy" />
          </div>
          <figcaption class="border-t border-slate-100 px-4 py-3 text-center">
            <p class="font-medium text-slate-800">年次サマリー</p>
            <p class="text-sm text-slate-500">年間利益・インボイス対象額を確認</p>
          </figcaption>
        </figure>

        <figure class="rounded-xl border-2 border-slate-300 bg-white overflow-hidden shadow-sm">
          <div class="aspect-[4/3] bg-white flex items-center justify-center p-3 cursor-zoom-in gallery-wrapper"
               role="button" tabindex="0" aria-label="月次サマリー画面を拡大">
            <img src="/images/screens/screen_getsujisum.png" alt="シンプル工事台帳 月次サマリー画面"
                 class="max-h-full max-w-full object-contain pointer-events-none" loading="lazy" />
          </div>
          <figcaption class="border-t border-slate-100 px-4 py-3 text-center">
            <p class="font-medium text-slate-800">月次サマリー</p>
            <p class="text-sm text-slate-500">月ごとの売上・原価・利益を自動集計</p>
          </figcaption>
        </figure>

        <figure class="rounded-xl border-2 border-slate-300 bg-white overflow-hidden shadow-sm">
          <div class="aspect-[4/3] bg-white flex items-center justify-center p-3 cursor-zoom-in gallery-wrapper"
               role="button" tabindex="0" aria-label="工事登録画面を拡大">
            <img src="/images/screens/screen_kojitoroku.png" alt="シンプル工事台帳 工事登録画面"
                 class="max-h-full max-w-full object-contain pointer-events-none" loading="lazy" />
          </div>
          <figcaption class="border-t border-slate-100 px-4 py-3 text-center">
            <p class="font-medium text-slate-800">工事登録</p>
            <p class="text-sm text-slate-500">工事名・施主・金額などをシンプルに記録</p>
          </figcaption>
        </figure>

      </div>
    </div>
  </section>


  <!-- S7：価格（安心の特徴を統合） -->
  <section class="py-16 bg-white">
    <div class="container-base">
      <h2 class="text-3xl font-bold text-primary-900 mb-10 text-center">価格</h2>
      <div class="max-w-md mx-auto border-2 border-accent-400 rounded-2xl p-10 shadow-lg text-center">
        <p class="text-lg font-bold text-slate-700 mb-2">シンプル工事台帳 ライト版</p>
        <p class="text-6xl font-bold text-accent-500 mb-1">¥{PRODUCT.price.toLocaleString()}</p>
        <hr class="border-slate-200 mb-8" />
        <ul class="space-y-3 text-left mb-10">
          {[
            '永続ライセンス',
            '同一事業者内の複数PCで利用可',
            '60日間メールサポート',
            '不具合の無償対応（60日以内）',
            'インストール不要、Excelで開くだけ',
            'マクロ不使用で「マクロ警告」が出ない',
