      >
        今すぐ購入
      </button>
    </div>
  </div>

<script>
  // モバイル下部固定バーの表示制御（IntersectionObserver）
  const stickyBar = document.getElementById('sticky-buy-bar');
  const heroBtn = document.getElementById('buy-btn-hero');
  if (stickyBar && heroBtn) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        const show = !entry.isIntersecting;
        stickyBar.classList.toggle('translate-y-full', !show);
        stickyBar.classList.toggle('translate-y-0', show);
        stickyBar.setAttribute('aria-hidden', String(!show));
      },
      { threshold: 0 }
    );
    observer.observe(heroBtn);
  }
</script>

