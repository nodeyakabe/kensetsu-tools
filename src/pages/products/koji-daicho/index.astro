<script>
  function initLightbox() {
    const lb = document.getElementById('ss-lightbox');
    const lbImg = document.getElementById('ss-lightbox-img');
    const closeBtn = document.getElementById('ss-lightbox-close');
    const mainEl = document.querySelector('main');
    if (!lb || !lbImg || !closeBtn) return;

    const prevAc = (window).__lbAbort;
    if (prevAc) prevAc.abort();
    const ac = new AbortController();
    (window).__lbAbort = ac;
    const sig = { signal: ac.signal };

    document.body.style.overflow = '';
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    mainEl?.removeAttribute('aria-hidden');

    let lastFocused = null;
    const preventTouch = (e) => e.preventDefault();

    const open = (src, alt) => {
      lastFocused = document.activeElement;
      lbImg.src = src; lbImg.alt = alt || '';
      lb.classList.remove('hidden'); lb.classList.add('flex');
      document.body.style.overflow = 'hidden';
      lb.addEventListener('touchmove', preventTouch, { passive: false, signal: ac.signal });
      mainEl?.setAttribute('aria-hidden', 'true');
      closeBtn.focus();
    };
    const close = () => {
      document.body.style.overflow = '';
      lb.removeEventListener('touchmove', preventTouch);
      lb.classList.add('hidden'); lb.classList.remove('flex');
      lbImg.src = '';
      mainEl?.removeAttribute('aria-hidden');
      lastFocused?.focus();
    };

    lb.addEventListener('keydown', (e) => { if (e.key === 'Tab') { e.preventDefault(); closeBtn.focus(); } }, sig);
    document.querySelectorAll('.gallery-wrapper').forEach((wrapper) => {
      const img = wrapper.querySelector('img');
      const handler = () => { if (img) open(img.currentSrc || img.src, img.alt); };
      wrapper.addEventListener('click', handler, sig);
      wrapper.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); handler(); } }, sig);
    });
    lb.addEventListener('click', (e) => { if (e.target === lb) close(); }, sig);
    closeBtn.addEventListener('click', close, sig);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); }, sig);
  }

  initLightbox();
  document.addEventListener('astro:page-load', initLightbox);
</script>

<script>
  // 購入ボタン：/api/create-checkout エンドポイント経由でStripe決済
  const BUY_IDS = ['buy-btn-hero', 'buy-btn-price'] as const;
  const allBuyBtns = () =>
    BUY_IDS.map(id => document.getElementById(id) as HTMLButtonElement | null)
            .filter(Boolean) as HTMLButtonElement[];

  function showToast() {
    const toast = document.getElementById('buy-toast');
    if (!toast) return;
    toast.classList.remove('hidden');
    toast.classList.add('flex');
    setTimeout(() => {
      toast.classList.add('hidden');
      toast.classList.remove('flex');
    }, 4000);
  }

  async function handleBuy(btn: HTMLButtonElement) {
    allBuyBtns().forEach(b => { b.disabled = true; });
    const original = btn.textContent;
    btn.textContent = '読み込み中…';
    try {
      const res = await fetch('/api/create-checkout', { method: 'POST' });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      if (!data?.url) throw new Error('no url');
      window.location.href = data.url;
    } catch {
      showToast();
      allBuyBtns().forEach(b => { b.disabled = false; });
      btn.textContent = original;
    }
  }

  async function handleSetBuy(btn: HTMLButtonElement) {
    const orig = btn.textContent;
    btn.disabled = true;
    btn.textContent = '読み込み中…';
    try {
      const res = await fetch('/api/create-checkout-set', { method: 'POST' });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      if (!data?.url) throw new Error('no url');
      window.location.href = data.url;
    } catch {
      showToast();
      btn.disabled = false;
      btn.textContent = orig ?? '';
    }
  }

  function initBuyButtons() {
    BUY_IDS.forEach(id => {
      const b = document.getElementById(id) as HTMLButtonElement | null;
      if (!b || b.dataset.buyInit) return;
      b.dataset.buyInit = '1';
      b.addEventListener('click', () => handleBuy(b!));
    });
    const setBtn = document.getElementById('buy-btn-set') as HTMLButtonElement | null;
    if (setBtn && !setBtn.dataset.buyInit) {
      setBtn.dataset.buyInit = '1';
      setBtn.addEventListener('click', () => handleSetBuy(setBtn));
    }
  }

  initBuyButtons();
  document.addEventListener('astro:page-load', initBuyButtons);
</script>

<!-- ===== 商品ページ専用アニメーション（スケール＋フェード） ===== -->
<style>
  @media (prefers-reduced-motion: no-preference) {
    .p-reveal {
      opacity: 0;
      transform: scale(0.95);
      transition: opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1),
                  transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .p-reveal.p-visible {
      opacity: 1;
      transform: scale(1);
    }
    /* カードスタガー */
    .p-stagger > .p-reveal:nth-child(1) { transition-delay: 0ms; }
    .p-stagger > .p-reveal:nth-child(2) { transition-delay: 80ms; }
    .p-stagger > .p-reveal:nth-child(3) { transition-delay: 160ms; }
    .p-stagger > .p-reveal:nth-child(4) { transition-delay: 240ms; }
    .p-stagger > .p-reveal:nth-child(5) { transition-delay: 320ms; }
    .p-stagger > .p-reveal:nth-child(6) { transition-delay: 400ms; }
  }
</style>
<script>
  // 商品ページ専用アニメーション初期化（astro:page-load対応）
  var _productObservers = window._productObservers || [];

  function initProductAnimations() {
    // 前回のObserverをすべてdisconnect
    _productObservers.forEach(function (o) { o.disconnect(); });
    _productObservers = [];

    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // --- p-reveal（スケール＋フェード） ---
    if (!reduced && 'IntersectionObserver' in window) {
      var revealObs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('p-visible');
            revealObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.p-reveal').forEach(function (el) { revealObs.observe(el); });
      _productObservers.push(revealObs);
    }

    // --- 最終CTAテキストアニメーション ---
    var ctaEl = document.getElementById('final-cta-text');
    if (ctaEl) {
      if (reduced) {
        ctaEl.style.opacity = '1';
        ctaEl.style.transform = 'none';
      } else if ('IntersectionObserver' in window) {
        var ctaObs = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              ctaEl.style.opacity = '1';
              ctaEl.style.transform = 'scale(1) translateY(0)';
              ctaObs.unobserve(ctaEl);
            }
          });
        }, { threshold: 0.4 });
        ctaObs.observe(ctaEl);
        _productObservers.push(ctaObs);
      }
    }

    // --- 固定ボタン：価格セクションが見えたら非表示 ---
    var btn = document.getElementById('fixed-buy-btn');
    var priceSection = document.getElementById('price');
    if (btn && priceSection && 'IntersectionObserver' in window) {
      var btnObs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            btn.style.opacity = '0';
            btn.style.pointerEvents = 'none';
          } else {
            btn.style.opacity = '1';
            btn.style.pointerEvents = '';
          }
        });
      }, { threshold: 0.1 });
      btnObs.observe(priceSection);
      _productObservers.push(btnObs);
    }

    window._productObservers = _productObservers;
  }

  initProductAnimations();
  document.addEventListener('astro:page-load', initProductAnimations);
</script>

</BaseLayout>
