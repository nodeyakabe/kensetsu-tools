---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { PRODUCT, ANZEN_DAICHO } from '@/data/product';
import PurchaseFlow from '@/components/PurchaseFlow.astro';

const siteUrl = (import.meta.env.SITE ?? 'https://kensetsu-tools.com').replace(/\/$/, '');
const priceValidUntil = `${new Date().getFullYear() + 1}-12-31`;

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": PRODUCT.name,
  "description": "確定申告がラクになる、Excelだけで動く工事管理ツール。収支管理に特化・マクロ不使用・買い切り。",
  "brand": { "@type": "Brand", "name": "建設業ツール工房" },
  "url": `${siteUrl}/products/koji-daicho/`,
  "image": `${siteUrl}/og/koji-daicho.png`,
  "offers": {
    "@type": "Offer",
    "price": String(PRODUCT.price),
    "priceCurrency": PRODUCT.currency,
    "availability": "https://schema.org/InStock",
    "url": `${siteUrl}/products/koji-daicho/`,
    "priceValidUntil": priceValidUntil
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "ツール・商品", "item": `${siteUrl}/products/` },
    { "@type": "ListItem", "position": 3, "name": PRODUCT.name, "item": `${siteUrl}/products/koji-daicho/` },
  ],
};

const features = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>`,
    title: '工事登録',
    desc: '工事名・施主・金額など5項目だけ。迷わず使える設計。',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="12" y2="14"/></svg>`,
    title: '原価入力',
    desc: '材料費・外注費・労務費を種別に分けて記録・集計。',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
    title: '月次・年次サマリー',
    desc: '売上・原価・利益を自動集計。確定申告の準備に直結。',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1-2-1z"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="16" y2="14"/></svg>`,
    title: 'インボイス番号管理',
    desc: '取引先のインボイス番号を一覧管理・対象別に集計。',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>`,
    title: '改正建設業法 入力支援',
    desc: '原価割れの参考表示や労務費の入力支援。※法令適合性は保証外',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><polyline points="9 15 12 18 15 15"/></svg>`,
    title: 'CSV出力',
    desc: '会計ソフトや税理士提出用に、CSV形式で書き出せます。',
  },
];

const comparisonRows = [
  { label: '価格',           vals: ['無料', '¥8,800前後（買い切り）', '月額4,000円〜', `¥${PRODUCT.price.toLocaleString()}（買い切り）`] },
  { label: 'マクロ',         vals: ['ものによる', 'あり（警告が出ることも）', '—（Web/アプリ）', 'なし（警告ゼロ）'] },
  { label: '確定申告の収支管理', vals: ['△ 自分で作り込む', '○', '○', '◎ これに特化'] },
  { label: '入力ミス防止',   vals: ['× 基本なし', '△', '○', '○（色で警告）'] },
  { label: '主な対象',       vals: ['Excelが得意な方', '中小〜の事業者', '法人・複数人の現場', '一人親方・ITが苦手な方'] },
];
---

<BaseLayout
  title="シンプル工事台帳 | 一人親方の確定申告用Excel工事台帳"
  description="一人親方・個人事業主向けのExcel工事台帳。工事ごとの収支を自動集計し確定申告がラクになります。インボイス番号管理・CSV出力対応。マクロ不使用・買い切り¥5,980。"
  ogImage="/og/koji-daicho.png"
  ogType="product"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- パンくず -->
  <div class="w-full px-4 sm:px-6 lg:px-10 py-3 bg-white border-b border-slate-100">
    <nav class="text-sm text-slate-500" aria-label="パンくずリスト">
      <ol class="flex items-center flex-wrap">
        <li><a href="/" class="hover:text-[#0F2557] transition-colors">ホーム</a></li>
        <li aria-hidden="true" class="mx-2">/</li>
        <li><a href="/products/" class="hover:text-[#0F2557] transition-colors">ツール・商品</a></li>
        <li aria-hidden="true" class="mx-2">/</li>
        <li aria-current="page" class="text-slate-700">シンプル工事台帳</li>
      </ol>
    </nav>
  </div>

  <!-- ===== S1：ヒーロー（カンプ案6・是正版 #34） ===== -->
  <section class="bg-white relative overflow-clip">

    <!-- 背景の装飾リング（デスクトップのみ） -->
    <div class="hidden lg:block absolute pointer-events-none" style="top:-340px; left:-460px; width:1400px; height:1300px; border:170px solid #E4EBF6; border-radius:50%; transform:rotate(-18deg);" aria-hidden="true"></div>
    <div class="hidden lg:block absolute pointer-events-none" style="top:430px; left:620px; width:900px; height:900px; border:120px solid #F3F6FB; border-radius:50%;" aria-hidden="true"></div>

    <div class="max-w-[1240px] mx-auto px-6 lg:px-10 pt-12 lg:pt-[56px] pb-20 lg:pb-[120px] relative">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.05fr] gap-10 lg:gap-[56px] items-start">

        <!-- 左：ビジュアルコンポジション -->

        <!-- デスクトップ（lg以上）: カンプ通りの絶対配置 -->
        <div class="hidden lg:block relative" style="min-height:540px;">
          <!-- 回り込む英字 -->
          <div class="absolute font-mono font-medium whitespace-nowrap text-[#8FA1C4]" style="top:170px; left:-10px; transform:rotate(-72deg); transform-origin:left top; font-size:21px; letter-spacing:0.28em;" aria-hidden="true">One-time purchase</div>
          <!-- 濃紺の太い円リング -->
          <div class="absolute rounded-full" style="top:14px; left:30px; width:430px; height:430px; border:38px solid #0F2557;"></div>
          <!-- クリーム色の小円 -->
          <div class="absolute rounded-full bg-[#FDEBC8]" style="top:396px; left:0; width:100px; height:100px;"></div>
          <!-- 白カード＋スクショ -->
          <div class="absolute bg-white" style="top:114px; left:62px; width:384px; border-radius:18px; padding:12px; transform:rotate(-2deg); box-shadow:0 4px 20px rgba(0,0,0,0.12);">
            <img
              src="/images/screens/screen_home.png"
              alt="シンプル工事台帳 ホーム画面"
              width="360"
              height="300"
              class="w-full block"
              style="height:300px; object-fit:cover; object-position:center top; border-radius:10px;"
              loading="eager"
            />
          </div>
          <!-- オレンジの大チェックマーク -->
          <div class="absolute" style="top:340px; left:366px; width:46px; height:92px; border-right:26px solid #F59E0B; border-bottom:26px solid #F59E0B; transform:rotate(42deg); border-radius:6px;"></div>
          <!-- ウタ（上） -->
          <img
            src="/images/characters/uta_product.png"
            alt="工房の案内係・ウタ"
            width="100"
            height="100"
            class="absolute object-contain"
            style="top:18px; left:78px; width:100px; height:100px; transform:rotate(-2deg);"
            loading="eager"
          />
          <!-- ナツ（下） -->
          <img
            src="/images/characters/natu_product.png"
            alt="工房の案内係・ナツ"
            width="106"
            height="106"
            class="absolute object-contain"
            style="top:386px; left:4px; width:106px; height:106px;"
            loading="eager"
          />
        </div>

        <!-- モバイル（lg未満）: 縮小版 -->
        <div class="lg:hidden flex flex-col items-center gap-6">
          <div class="relative flex items-center justify-center" style="width:280px; height:280px;">
            <!-- 濃紺リング -->
            <div class="absolute inset-0 rounded-full" style="border:28px solid #0F2557;"></div>
            <!-- スクショ -->
            <div class="w-[190px] bg-white rounded-2xl p-2" style="box-shadow:0 4px 16px rgba(0,0,0,0.12); transform:rotate(-2deg);">
              <img
                src="/images/screens/screen_home.png"
                alt="シンプル工事台帳 ホーム画面"
                class="w-full block rounded-xl"
                style="height:150px; object-fit:cover; object-position:center top;"
                loading="eager"
              />
            </div>
            <!-- オレンジチェック（簡略） -->
            <div class="absolute" style="bottom:20px; right:14px; width:26px; height:52px; border-right:14px solid #F59E0B; border-bottom:14px solid #F59E0B; transform:rotate(42deg); border-radius:4px;"></div>
            <!-- クリーム小円 -->
            <div class="absolute rounded-full bg-[#FDEBC8]" style="bottom:4px; left:8px; width:48px; height:48px;"></div>
          </div>
          <!-- キャラクター -->
          <div class="flex gap-4 items-end">
            <img src="/images/characters/uta_product.png" alt="工房の案内係・ウタ" width="80" height="80" class="w-[80px] h-[80px] object-contain" loading="eager" />
            <img src="/images/characters/natu_product.png" alt="工房の案内係・ナツ" width="86" height="86" class="w-[86px] h-[86px] object-contain" loading="eager" />
          </div>
        </div>

        <!-- 右：コピー -->
        <div class="flex flex-col gap-6 justify-center text-center lg:text-left">

          <!-- バッジ -->
          <div class="self-center lg:self-start" style="border:1.5px solid #0F2557; color:#0F2557; font-size:14px; font-weight:700; padding:9px 26px; border-radius:999px; display:inline-block;">
            一人親方・個人事業主向け 工事収支管理Excel
          </div>
          <!-- h1 -->
          <h1 class="text-[36px] sm:text-[42px] font-black leading-[1.6] text-[#1A2B4A] tracking-[0.06em] m-0">
            工事の収支を<br>記録、集計、申告準備。
          </h1>
          <!-- 説明文 -->
          <p class="text-[15px] leading-[2.2] text-[#44536E] tracking-[0.06em] max-w-[520px] mx-auto lg:mx-0 m-0">
            「シンプル工事台帳」は、工事ごとの入金と支出を記録するだけで、確定申告に使える収支がまとまるExcelの工事台帳です。マクロなし・インストール不要で、今日から使えます。
          </p>
          <!-- 価格 -->
          <div class="flex items-baseline gap-1.5 flex-wrap justify-center lg:justify-start">
            <span class="text-[15px] font-bold text-[#0F2557]">買い切り</span>
            <span class="text-[40px] font-black text-[#0F2557]" style="border-bottom:4px solid #F59E0B;">¥{PRODUCT.price.toLocaleString()}</span>
            <span class="text-[13px] text-[#5A6B85]">税込・月額なし</span>
          </div>
          <!-- バッジ3つ -->
          <div class="flex gap-2 flex-wrap justify-center lg:justify-start">
            {['✓ マクロなし', '✓ インストール不要', '✓ 3分で使い始め'].map(b => (
              <span class="bg-[#E4EBF6] rounded-full px-[18px] py-[7px] text-[12.5px] font-bold text-[#0F2557]">{b}</span>
            ))}
          </div>
          <!-- 購入ボタン -->
          <div class="flex flex-col items-center lg:items-start pt-2 gap-2">
            <button
              id="buy-btn-hero"
              type="button"
              class="bg-[#F59E0B] hover:bg-[#D98908] text-white font-bold px-8 py-4 rounded-full text-base transition-colors btn-press"
            >
              ¥{PRODUCT.price.toLocaleString()}で購入する（追加費用なし）
            </button>
            <p class="text-xs text-[#5A6B85] text-center lg:text-left leading-relaxed">
              ✓ 決済完了後すぐにメールでお届け<br>※ デジタル商品のため返品はできません。動作環境を満たすPCで動作しない場合は、確認のうえ修正版のご提供または返金で対応します。
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== 購入の流れ ===== -->
  <div class="bg-white py-10 border-b border-[#E9EDF3]">
    <PurchaseFlow productType="excel" />
  </div>

  <!-- ===== S2：悩み（PROBLEM） ===== -->
  <section class="bg-[#E4EBF6] relative overflow-clip rounded-t-[40px] sm:rounded-t-[80px] pt-16 sm:pt-20 pb-16">
    <!-- 装飾円 -->
    <div class="absolute pointer-events-none" style="top:-200px; right:-300px; width:800px; height:800px; border-radius:50%; background:#DDE6F2;" aria-hidden="true"></div>

    <div class="max-w-[1240px] mx-auto px-6 lg:px-10 relative">
      <!-- バッジ -->
      <div class="flex justify-center mb-6 p-reveal">
        <span class="bg-white rounded-full px-5 py-2 font-mono text-[11px] tracking-[0.22em] text-[#44536E] font-medium">PROBLEM — こんな悩みありませんか？</span>
      </div>
      <h2 class="text-[28px] sm:text-[34px] font-black text-[#0F2557] text-center mb-10 leading-snug tracking-[0.04em] p-reveal">事務作業が、現場の時間を削っていく。</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 p-stagger">
        <!-- 白カード×5 -->
        {[
          { title: '工事台帳の管理が面倒', desc: '紙やExcel自作での管理は、つくるのも続けるのも大変。' },
          { title: '確定申告の準備が毎年大変', desc: '1年分の領収書と通帳を前に、2月の夜が長くなる。' },
          { title: 'サブスクの固定費がかさむ', desc: '業務ソフトは月額制ばかり。使う回数のわりに高くつく。' },
          { title: '制度対応が不安', desc: 'インボイス制度や改正建設業法。何をすればいいのか。' },
          { title: 'ITに詳しくない', desc: 'パソコンは苦手。でも、何か始めなきゃとは思っている。' },
        ].map(card => (
          <div class="bg-white rounded-2xl p-6 p-reveal" style="box-shadow:0 2px 8px rgba(0,0,0,0.06);">
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full bg-[#FDEBC8] flex items-center justify-center flex-shrink-0 text-[#D97706] font-black text-sm">！</div>
              <div>
                <p class="font-bold text-[#0F2557] text-[19px] mb-1">{card.title}</p>
                <p class="text-[#44536E] text-[17px] leading-relaxed">{card.desc}</p>
              </div>
            </div>
          </div>
        ))}
        <!-- 濃紺アクセントカード（損失回避） -->
        <div class="rounded-2xl p-6 p-reveal" style="background:#0F2557; box-shadow:0 2px 8px rgba(0,0,0,0.12);">
          <p class="font-bold text-[#F59E0B] text-[13px] mb-2 leading-snug tracking-wide">事務の1日が、現場の利益を消す。</p>
          <p class="font-bold text-white text-[15px] mb-2 leading-snug">その事務作業、この台帳ひとつで軽くなります。</p>
          <p class="text-[#8FA1C4] text-[17px] leading-relaxed">入力するのは、工事と入金と支出だけ。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== S3：機能（FUNCTION） ===== -->
  <section id="features" class="bg-white relative mt-[-40px] rounded-t-[40px] sm:rounded-t-[80px] pt-16 sm:pt-20 pb-16">
    <div class="max-w-[1240px] mx-auto px-6 lg:px-10">
      <!-- バッジ -->
      <div class="flex justify-center mb-6 p-reveal">
        <span class="bg-[#E4EBF6] rounded-full px-5 py-2 font-mono text-[11px] tracking-[0.22em] text-[#44536E] font-medium">FUNCTION — 主な機能</span>
      </div>
      <h2 class="text-[28px] sm:text-[34px] font-black text-[#0F2557] text-center mb-10 leading-snug p-reveal">「この工事、儲かったのか？」に、すぐ答えられる。</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 p-stagger">
        {features.map((f, i) => (
          <div class="rounded-2xl p-6 p-reveal" style="background:#F3F6FB;">
            <div class="font-mono text-[11px] tracking-[0.22em] text-[#8FA1C4] mb-3">{String(i + 1).padStart(2, '0')}</div>
            <div class="text-[#F59E0B] mb-3" set:html={f.icon} />
            <h3 class="font-bold text-[#0F2557] text-[19px] mb-1">{f.title}</h3>
            <p class="text-[#44536E] text-[17px] leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== S4：比較（COMPARISON）+ ウタ・ナツのコメント ===== -->
  <section class="bg-white pt-16 sm:pt-20 pb-16">
    <div class="max-w-[1240px] mx-auto px-6 lg:px-10">
      <!-- バッジ -->
      <div class="flex justify-center mb-6 p-reveal">
        <span class="bg-[#E4EBF6] rounded-full px-5 py-2 font-mono text-[11px] tracking-[0.22em] text-[#44536E] font-medium">COMPARISON</span>
      </div>
      <h2 class="text-[28px] sm:text-[34px] font-black text-[#0F2557] text-center mb-3 leading-snug p-reveal">他のツールと比べてみると</h2>
      <p class="text-[#44536E] text-[17px] text-center mb-10 max-w-xl mx-auto p-reveal">用途が違うだけで、どれも正解です。本品が合うかどうか確認してください。</p>

      <!-- デスクトップ比較テーブル（md以上） -->
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-sm border-collapse min-w-[700px]" style="border-radius:16px; overflow:hidden;">
          <thead>
            <tr>
              <th scope="col" class="text-left px-5 py-3.5 bg-[#F3F6FB] text-[#44536E] font-medium" style="border-radius:16px 0 0 0; width:22%">比較項目</th>
              <th scope="col" class="px-4 py-3.5 bg-[#F3F6FB] text-[#44536E] font-medium text-center border-l border-[#E2E8F0]">無料Excelテンプレ</th>
              <th scope="col" class="px-4 py-3.5 bg-[#F3F6FB] text-[#44536E] font-medium text-center border-l border-[#E2E8F0]">市販の工事台帳<br/><span class="text-xs font-normal text-[#8FA1C4]">（日本法令 等）</span></th>
              <th scope="col" class="px-4 py-3.5 bg-[#F3F6FB] text-[#44536E] font-medium text-center border-l border-[#E2E8F0]">クラウド型<br/><span class="text-xs font-normal text-[#8FA1C4]">（月額サービス）</span></th>
              <th scope="col" class="px-4 py-3.5 text-white font-bold text-center border-l border-[#0B1C42]" style="background:#0F2557; border-radius:0 16px 0 0;">本品</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row, i) => (
              <tr style={i % 2 === 0 ? 'background:#FFFFFF' : 'background:#FAFBFD'}>
                <td class="px-5 py-3.5 text-[#44536E] font-medium border-t border-[#E8EEF6]">{row.label}</td>
