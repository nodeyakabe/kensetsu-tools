---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ComingSoonCard from '@/components/ComingSoonCard.astro';
import { comingSoonItems } from '@/data/coming-soon';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://kensetsu-tools.com/" },
    { "@type": "ListItem", "position": 2, "name": "ツール・商品", "item": "https://kensetsu-tools.com/products/" },
  ],
};
---

<BaseLayout
  title="ツール・商品｜一人親方向けExcel工事台帳"
  description="一人親方・小規模建設業向けの業務ツール一覧。確定申告に直結するExcel工事台帳「シンプル工事台帳 ライト版」（買い切り¥5,980・マクロ不使用）を発売中。Windows・Mac対応。"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <div class="container-base py-16">
    <nav class="text-sm text-slate-500 mb-10" aria-label="パンくずリスト">
      <a href="/" class="hover:text-primary-600 transition-colors">ホーム</a>
      <span class="mx-2">/</span>
      <span class="text-slate-700">ツール・商品</span>
    </nav>

    <div class="mb-12">
      <h1 class="text-4xl font-bold text-primary-900 mb-3">ツール・商品</h1>
      <p class="text-slate-500 text-lg">建設業の現場で本当に使えるツールをお届けします。</p>
    </div>

    <!-- 発売中 -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      <a href="/products/koji-daicho/" class="block group col-span-full md:col-span-1">
        <div class="bg-white border-2 border-accent-400 rounded-xl p-8 hover:shadow-md transition-all duration-200 h-full">
          <div class="mb-4">
            <span class="inline-block bg-accent-500 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">発売中</span>
          </div>
          <h2 class="text-2xl font-bold text-primary-900 mb-2 group-hover:text-primary-700 transition-colors">
            シンプル工事台帳 ライト版
          </h2>
          <p class="text-slate-600 text-base mb-4">
            確定申告がラクになる、Excelだけで動く工事管理ツール
          </p>
          <p class="text-accent-500 text-xl font-semibold mb-1">¥5,980（税込・買い切り）</p>
          <p class="text-slate-400 text-sm mb-6">返金保証なし</p>
          <span class="text-primary-600 font-bold group-hover:text-primary-800 transition-colors">
            詳細・購入はこちら →
          </span>
        </div>
      </a>
    </div>

    <!-- 今後のラインナップ -->
    <div>
      <h2 class="text-2xl font-bold text-primary-900 mb-2">今後のラインナップ</h2>
      <p class="text-slate-500 text-sm mb-8">順次提供予定です（提供時期は未定）。</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {comingSoonItems.map(card => (
          <ComingSoonCard title={card.title} desc={card.desc} />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
