---
import BaseLayout from '@/layouts/BaseLayout.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://kensetsu-tools.com/" },
    { "@type": "ListItem", "position": 2, "name": "ツール・商品", "item": "https://kensetsu-tools.com/products/" },
  ],
};
---

<BaseLayout
  title="ツール・商品"
  description="建設業の現場で本当に使えるツールをお届けします。シンプル工事台帳ライト版を近日リリース予定。"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <div class="container-base py-16">
    <nav class="text-sm text-slate-500 mb-10" aria-label="パンくずリスト">
      <a href="/" class="hover:text-primary-600 transition-colors">ホーム</a>
      <span class="mx-2">/</span>
      <span class="text-slate-700">ツール・商品</span>
    </nav>

    <div class="mb-12">
      <h1 class="text-4xl font-bold text-primary-900 mb-3">ツール・商品</h1>
      <p class="text-slate-500 text-lg">建設業の現場で本当に使えるツールをお届けします。</p>
    </div>

    <div class="max-w-2xl">
      <a href="/products/koji-daicho/" class="block group">
        <div class="bg-white border border-slate-200 rounded-xl p-8 hover:shadow-md hover:border-slate-300 transition-all duration-200">
          <div class="mb-4">
            <span class="inline-block bg-accent-500 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">近日リリース</span>
          </div>
          <h2 class="text-2xl font-bold text-primary-900 mb-2 group-hover:text-primary-700 transition-colors">
            シンプル工事台帳 ライト版
          </h2>
          <p class="text-slate-600 text-lg mb-4">
            確定申告がラクになる、Excelだけで動く工事管理ツール
          </p>
          <p class="text-accent-500 text-xl font-semibold mb-1">¥5,980（買い切り）</p>
          <p class="text-slate-400 text-sm mb-6">2026年内リリース予定</p>
          <span class="text-primary-600 font-bold group-hover:text-primary-800 transition-colors">
            詳細を見る →
          </span>
        </div>
      </a>
    </div>
  </div>
</BaseLayout>
