<script>
  // ===== 購入ボタン =====
  function showKbToast() {
    const t = document.getElementById('kb-buy-toast');
    if (!t) return;
    t.style.display = 'flex';
    setTimeout(() => { t.style.display = 'none'; }, 4000);
  }

  async function handleKbBuy(btn: HTMLButtonElement) {
    const orig = btn.textContent;
    btn.disabled = true;
    btn.textContent = '読み込み中…';
    try {
      const res = await fetch('/api/create-checkout-kb', { method: 'POST' });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      if (!data?.url) throw new Error('no url');
      window.location.href = data.url;
    } catch {
      showKbToast();
      btn.disabled = false;
      btn.textContent = orig ?? '';
    }
  }

  function initKbBuyButtons() {
    const b = document.getElementById('buy-btn-kb') as HTMLButtonElement | null;
    if (!b || b.dataset.buyInit) return;
    b.dataset.buyInit = '1';
    b.addEventListener('click', () => handleKbBuy(b!));
  }

  initKbBuyButtons();
  document.addEventListener('astro:page-load', initKbBuyButtons);

  // ===== アニメーション =====
  var _kbObservers: IntersectionObserver[] = (window as any)._kbObservers || [];

  function initKbAnimations() {
    _kbObservers.forEach(function(o) { o.disconnect(); });
    _kbObservers = [];

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced || !('IntersectionObserver' in window)) return;

    const obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('kb-visible');
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08 });

    document.querySelectorAll('.kb-reveal, .kb-reveal-left, .kb-reveal-right').forEach(function(el) { obs.observe(el); });
    _kbObservers.push(obs);
    (window as any)._kbObservers = _kbObservers;
  }

  initKbAnimations();
  document.addEventListener('astro:page-load', initKbAnimations);
</script>
