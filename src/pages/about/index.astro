---
import BaseLayout from '@/layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.SITE ?? 'https://kensetsu-tools.com').replace(/\/$/, '');

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム",              "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "このサイトについて",  "item": `${siteUrl}/about/` },
  ],
};
---

<BaseLayout
  title="このサイトについて"
  description="建設業ツール工房は、一人親方から10人規模の建設事業者向けに、買い切り（月額なし）の業務ツールと実務情報を届ける個人運営の工房です。サブスクなし・完全オフライン・ITが苦手な方でも使えるシンプルさを大切にしています。"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- パンくず -->
  <div class="w-full px-4 sm:px-6 lg:px-10 py-3 bg-white border-b border-slate-100">
    <nav class="text-sm text-slate-500" aria-label="パンくずリスト">
      <a href="/" class="hover:text-[#0F2557] transition-colors">ホーム</a>
      <span class="mx-2">/</span>
      <span class="text-[#1A2B4A]">このサイトについて</span>
    </nav>
  </div>

  <!-- ヒーロー：所信表明（ネイビー） -->
  <section class="bg-[#0F2557] relative overflow-hidden">
    <!-- 装飾円 -->
    <div class="hidden lg:block absolute -top-[200px] -right-[260px] w-[720px] h-[720px] rounded-full border-[80px] border-[#14305F]"></div>
    <div class="max-w-[1180px] mx-auto px-6 lg:px-10 pt-20 pb-28 relative flex flex-col gap-6">
      <p class="font-mono text-xs tracking-[0.2em] text-[#8FA1C4]">ABOUT — このサイトについて</p>
      <h1 class="text-[36px] lg:text-[40px] font-black leading-[1.6] text-white tracking-[0.05em] max-w-[880px]">
        事務しごとを、<span class="text-[#F59E0B]">道具</span>で軽くする。<br>
        それが、この工房の役目です。
      </h1>
      <p class="text-[15px] leading-[2.1] text-[#C7D2E5] tracking-[0.04em] max-w-[640px]">
        建設業ツール工房は、一人親方から10人規模の建設事業者のために、買い切り（月額なし）の業務ツールと実務情報を届ける、個人運営の小さな工房です。
      </p>
    </div>
  </section>

  <!-- 工房について（白の曲面立ち上がり） -->
  <section class="bg-white rounded-[80px_80px_0_0] -mt-10 relative">
    <div class="max-w-[1180px] mx-auto px-6 lg:px-10 pt-20 pb-16 flex flex-col gap-9">
      <div class="flex flex-col items-center gap-4 text-center">
        <span class="border border-[#0F2557] text-[#0F2557] text-[13px] font-bold px-7 py-2 rounded-full">MISSION — 工房について</span>
        <h2 class="text-[30px] font-black text-[#0F2557] tracking-[0.04em]">なぜ、この工房をつくったか</h2>
      </div>
      <div class="max-w-[820px] mx-auto flex flex-col gap-5 text-[15px] leading-[2.2] text-[#44536E] text-center">
        <p>建設業の現場では、見積・請求・工事台帳・確定申告と、事務しごとが次々に積み上がります。とくに一人親方や少人数の事業者では、その多くを現場の合間や夜にこなすことになりがちです。</p>
        <p>高機能な専用システムでも、毎月の費用がかかるクラウドでもなく、<strong class="text-[#0F2557]">買い切りで、説明書がなくても使える道具</strong>を。その一点のために、この工房はツールを一つずつ作っています。</p>
      </div>
    </div>
  </section>

  <!-- 3つの方針 -->
  <section class="bg-white">
    <div class="max-w-[1180px] mx-auto px-6 lg:px-10 pb-20 flex flex-col gap-9">
      <div class="flex flex-col items-center gap-4 text-center">
        <span class="border border-[#0F2557] text-[#0F2557] text-[13px] font-bold px-7 py-2 rounded-full">POLICY — 大切にしている3つの方針</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-[18px]">
        {[
          {
            num: '01',
            title: '買い切りで、ずっと使える',
            desc: '月額やサブスクではなく、一度のお支払いで使い続けられる形に。更新料や追加費用はいただきません。',
          },
          {
            num: '02',
            title: 'ITが苦手な方を基準に',
            desc: '機能の多さより、迷わず操作できることを優先。開いたその日から使える設計を心がけています。',
          },
          {
            num: '03',
            title: '誠実に、正直に',
            desc: 'できること・できないことを正直に。制度に関わる情報は、わかる範囲と限界を明記します。',
          },
        ].map(item => (
          <div class="border border-[#E3E8F0] border-t-[3px] border-t-[#0F2557] rounded-b-[14px] p-[30px_28px] flex flex-col gap-3">
            <p class="font-mono text-[13px] text-[#F59E0B] font-medium">{item.num}</p>
            <p class="text-[17px] font-black text-[#0F2557]">{item.title}</p>
            <p class="text-[13.5px] leading-[2] text-[#5A6B85]">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 運営者情報（ネイビー曲面） -->
  <section class="bg-[#0F2557] rounded-[80px_80px_0_0] relative overflow-hidden">
    <!-- 装飾円 -->
    <div class="hidden lg:block absolute -bottom-[200px] -left-[180px] w-[560px] h-[560px] rounded-full border-[70px] border-[#14305F]"></div>
    <div class="max-w-[1180px] mx-auto px-6 lg:px-10 py-20 relative flex flex-col gap-9">
      <div class="flex flex-col items-center gap-4 text-center">
        <span class="border border-[#4A5E8C] text-[#DCE4F1] text-[13px] font-bold px-7 py-2 rounded-full">PROFILE — 運営者情報</span>
        <h2 class="text-[30px] font-black text-white tracking-[0.04em]">運営者について</h2>
      </div>
      <!-- テーブル -->
      <div class="max-w-[900px] mx-auto w-full bg-white rounded-2xl overflow-hidden">
        <table class="w-full text-[14px]">
          <tbody>
            {[
              { label: '屋号',           value: '建設業ツール工房' },
              { label: '運営形態',       value: '個人による運営' },
              { label: '事業内容',       value: '建設業向け業務ツールの企画・販売／実務情報の発信' },
              { label: '所在地',         value: '特定商取引法に基づく表記に記載' },
              { label: 'お問い合わせ',   value: 'お問い合わせフォームにて受付' },
              { label: 'サイト開設',     value: '2026年' },
            ].map((row, i, arr) => (
              <tr class={i !== arr.length - 1 ? 'border-b border-[#E3E8F0]' : ''}>
                <th class="w-[180px] px-6 py-4 bg-[#F4F6F9] text-left font-bold text-[#0F2557] align-top">{row.label}</th>
                <td class="px-6 py-4 text-[#44536E]">{row.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <!-- リンク -->
      <div class="flex gap-3 flex-wrap justify-center">
        <a href="/sct/" class="border border-[#4A5E8C] text-white font-bold text-[13px] px-[22px] py-[10px] rounded-lg hover:border-white transition-colors">特定商取引法に基づく表記</a>
        <a href="/privacy/" class="border border-[#4A5E8C] text-white font-bold text-[13px] px-[22px] py-[10px] rounded-lg hover:border-white transition-colors">プライバシーポリシー</a>
        <a href="/terms/" class="border border-[#4A5E8C] text-white font-bold text-[13px] px-[22px] py-[10px] rounded-lg hover:border-white transition-colors">利用規約</a>
      </div>
    </div>
  </section>

  <!-- 案内役（白の曲面立ち上がり） -->
  <section class="bg-white rounded-[80px_80px_0_0] -mt-10 relative">
    <div class="max-w-[1180px] mx-auto px-6 lg:px-10 pt-20 pb-18 flex flex-col gap-9">
      <div class="flex flex-col items-center gap-4 text-center">
        <span class="border border-[#0F2557] text-[#0F2557] text-[13px] font-bold px-7 py-2 rounded-full">MASCOT — 案内役の紹介</span>
        <h2 class="text-[30px] font-black text-[#0F2557] tracking-[0.04em]">看板猫が、ご案内します</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-[18px] max-w-[820px] mx-auto w-full">
        <div class="bg-[#F3F6FB] rounded-2xl p-[26px] flex gap-[18px] items-center">
          <img src="/images/characters/uta_product.png" alt="建設業ツール工房のキャラクター ウタ" class="w-20 h-20 object-contain flex-shrink-0" loading="lazy" />
          <div class="flex flex-col gap-1">
            <p class="text-[16px] font-black text-[#0F2557]">黒猫の ウタ</p>
            <p class="text-[13px] leading-[1.8] text-[#5A6B85]">監督役。要点をかいつまんで案内します。</p>
          </div>
        </div>
        <div class="bg-[#F3F6FB] rounded-2xl p-[26px] flex gap-[18px] items-center">
          <img src="/images/characters/natu_product.png" alt="建設業ツール工房のキャラクター ナツ" class="w-20 h-20 object-contain flex-shrink-0" loading="lazy" />
          <div class="flex flex-col gap-1">
            <p class="text-[16px] font-black text-[#0F2557]">三毛猫の ナツ</p>
            <p class="text-[13px] leading-[1.8] text-[#5A6B85]">職人役。やさしい言葉に置きかえて手伝います。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-white pb-24 pt-4">
    <div class="max-w-[1180px] mx-auto px-6 lg:px-10 flex flex-col items-center gap-5 text-center">
      <h2 class="text-[28px] font-black text-[#0F2557] tracking-[0.04em]">お気軽にご相談ください</h2>
      <p class="text-[14px] leading-[1.9] text-[#5A6B85]">「こんな道具がほしい」というご意見も、次のツールづくりの参考にしています。</p>
      <a href="/contact/" class="bg-[#F59E0B] text-white font-bold text-[16px] px-10 py-4 rounded-lg hover:bg-[#D98908] transition-colors">お問い合わせフォームへ</a>
    </div>
  </section>

</BaseLayout>
