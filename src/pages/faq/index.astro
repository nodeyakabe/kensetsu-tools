---
import BaseLayout from '@/layouts/BaseLayout.astro';

const faqs = [
  {
    q: 'シンプル工事台帳はどんな人向けですか？',
    a: '一人親方・個人事業主の建設業者の方を主な対象としています。特に確定申告や工事の収支管理をシンプルに行いたい方、ITに不慣れな方でも安心して使えるよう設計しています。',
  },
  {
    q: 'マクロ（VBA）は使われていますか？',
    a: 'マクロ（VBA）は一切使用していません。通常のExcel関数のみで動作するため、マクロを無効にした環境や、セキュリティ設定の厳しい職場のPCでも問題なく使用できます。',
  },
  {
    q: 'Macでも使えますか？',
    a: 'Microsoft 365（Excel for Mac）がインストールされていれば、Macでもご利用いただけます。ただし、一部のレイアウトや表示が異なる場合があります。',
  },
  {
    q: 'インボイス制度（適格請求書等保存方式）に対応していますか？',
    a: '登録番号の記入欄や、インボイス制度に対応した請求書・工事台帳の記載項目を含めた設計としています。詳細はリリース時の商品ページをご確認ください。',
  },
  {
    q: 'サポートはどうなっていますか？',
    a: 'メールによるサポートを提供しています。お問い合わせはサイト内のお問い合わせフォームまたは contact@kensetsu-tools.com までご連絡ください。個人運営のため返答にお時間をいただく場合があります。',
  },
  {
    q: '複数のPCで使えますか？',
    a: 'Excelファイル形式での提供のため、ファイルをコピー・移動することで複数のPCでご利用いただけます。クラウドストレージ（OneDrive・Google Drive等）に保存することで、複数端末からのアクセスも可能です。',
  },
  {
    q: 'データはどこに保存されますか？',
    a: 'データはお使いのPCまたは任意のストレージにExcelファイルとして保存されます。当サイトのサーバーや外部クラウドにデータが送信されることはありません。',
  },
  {
    q: '他の会計ソフト（freee・弥生等）と連携できますか？',
    a: '直接の連携機能はありませんが、CSV形式でのデータ出力に対応する予定です。各会計ソフトのCSV取込機能を利用することで、手入力の手間を削減できます。',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://kensetsu-tools.com/" },
    { "@type": "ListItem", "position": 2, "name": "よくある質問", "item": "https://kensetsu-tools.com/faq/" },
  ],
};
---

<BaseLayout
  title="よくある質問"
  description="シンプル工事台帳をはじめ、建設業ツール工房のサービスに関するよくある質問をまとめています。"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <div class="container-base py-16">
    <nav class="text-sm text-slate-500 mb-10" aria-label="パンくずリスト">
      <a href="/" class="hover:text-primary-600 transition-colors">ホーム</a>
      <span class="mx-2">/</span>
      <span class="text-slate-700">よくある質問</span>
    </nav>

    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl font-bold text-primary-900 mb-4">よくある質問</h1>
      <p class="text-slate-500 mb-12 text-lg">
        シンプル工事台帳・建設業ツール工房に関するご質問をまとめました。
      </p>

      <dl class="space-y-4">
        {faqs.map((faq, i) => (
          <div class="border border-slate-200 rounded-xl overflow-hidden">
            <dt>
              <button
                class="w-full flex items-start justify-between gap-4 px-6 py-5 text-left font-bold text-slate-900 hover:bg-slate-50 transition-colors"
                aria-expanded="false"
                aria-controls={`faq-answer-${i}`}
                id={`faq-btn-${i}`}
              >
                <span class="flex gap-3 items-start">
                  <span class="text-primary-600 font-black text-sm mt-0.5 flex-shrink-0">Q</span>
                  <span>{faq.q}</span>
                </span>
                <svg
                  class="faq-chevron flex-shrink-0 w-5 h-5 text-slate-400 mt-0.5 transition-transform duration-200"
                  fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
            </dt>
            <dd
              id={`faq-answer-${i}`}
              role="region"
              aria-labelledby={`faq-btn-${i}`}
              class="hidden px-6 pb-5 text-slate-600 leading-relaxed"
            >
              <div class="flex gap-3 items-start pt-1 border-t border-slate-100">
                <span class="text-accent-500 font-black text-sm mt-0.5 flex-shrink-0">A</span>
                <span>{faq.a}</span>
              </div>
            </dd>
          </div>
        ))}
      </dl>

      <div class="mt-14 bg-primary-50 border border-primary-100 rounded-xl p-8 text-center">
        <p class="text-slate-700 font-medium mb-4">解決しない場合はお気軽にご連絡ください</p>
        <a href="/contact/" class="inline-block bg-primary-600 hover:bg-primary-700 text-white font-bold px-6 py-3 rounded-lg transition-colors">
          お問い合わせはこちら
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('[id^="faq-btn-"]').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const answerId = btn.getAttribute('aria-controls')!;
      const answer = document.getElementById(answerId)!;
      const chevron = btn.querySelector('.faq-chevron')!;

      btn.setAttribute('aria-expanded', String(!expanded));
      answer.classList.toggle('hidden', expanded);
      chevron.classList.toggle('rotate-180', !expanded);
    });
  });
</script>
