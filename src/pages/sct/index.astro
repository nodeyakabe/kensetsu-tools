---
import BaseLayout from '@/layouts/BaseLayout.astro';

const operatorName = '矢ヶ部 隼人';
// ↓ HP公開日（商品リリース日）に変更してください
const establishedDate = '2026年5月25日';
---

<BaseLayout
  title="特定商取引法に基づく表記"
  description="建設業ツール工房の特定商取引法に基づく表記です。"
>
  <div class="w-full bg-white border-b border-[#D8DEE8]">
    <div class="max-w-[1160px] mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="text-sm text-[#5A6B85]" aria-label="パンくずリスト">
        <a href="/" class="hover:text-[#0F2557] transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <span class="text-[#1A2B4A]">特定商取引法に基づく表記</span>
      </nav>
    </div>
  </div>

  <div class="max-w-[1160px] mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl font-black text-[#0F2557] mb-3">特定商取引法に基づく表記</h1>
      <p class="text-[#5A6B85] text-sm mb-12 pb-12 border-b border-[#D8DEE8]">
        特定商取引に関する法律第11条に基づく表示
      </p>

      <div class="bg-white border border-[#D8DEE8] rounded-2xl overflow-hidden mb-8">
        <table class="w-full text-sm">
          <tbody class="divide-y divide-[#D8DEE8]">
            {[
              ['販売業者', '建設業ツール工房（屋号）'],
              ['運営責任者', operatorName],
              ['所在地', '請求があった場合に遅滞なく開示いたします'],
              ['電話番号', '請求があった場合に遅滞なく開示いたします'],
              ['メールアドレス', 'contact@kensetsu-tools.com'],
              ['販売URL', 'https://kensetsu-tools.com/'],
              ['商品・サービス', '建設業向けデジタルコンテンツ（テンプレート・ツール等）'],
              ['販売価格', '各商品ページに記載（消費税込み）'],
              ['商品代金以外の必要料金', 'なし（送料・手数料等は発生しません）'],
              ['支払方法', 'クレジットカード決済（Visa, Mastercard, JCB, American Express, Diners Club）'],
              ['決済代行', 'Stripe Payments Japan 株式会社'],
              ['支払時期', 'ご注文時にお支払いいただきます'],
              ['商品の引渡時期', '決済完了後、即時にダウンロードURLをメールにてお送りいたします'],
              ['動作環境', '各商品ページに記載'],
            ].map(([label, value]) => (
              <tr>
                <th class="py-4 px-6 text-left text-[#5A6B85] font-medium bg-[#EFF2F7] w-44 align-top">{label}</th>
                <td class="py-4 px-6 text-[#1A2B4A] leading-relaxed">{value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="prose prose-slate prose-lg max-w-none">
        <h2>返品・交換・キャンセルについて</h2>
        <p>
          本商品はデジタルコンテンツ（ダウンロード商品）のため、購入後の返品・交換・キャンセルは原則お受けできません。
        </p>
        <p>ただし、以下の場合は対応いたします：</p>
        <ul>
          <li>商品ファイルに不具合がある場合（購入から60日以内）</li>
          <li>商品ページ記載の動作環境を満たすにもかかわらず動作しない場合</li>
        </ul>
        <p>
          上記に該当する場合は、無償修正版の提供または返金にて対応いたします。
          詳細は <a href="mailto:contact@kensetsu-tools.com">contact@kensetsu-tools.com</a> までお問い合わせください。
        </p>

        <h2>注意事項</h2>
        <ul>
          <li>本表記の内容は予告なく変更する場合があります。最新情報は本ページにてご確認ください。</li>
          <li>各商品の詳細仕様・動作環境については、商品ページの記載をご確認ください。</li>
          <li>
            「所在地」「電話番号」は、
            <a href="/contact/">お問い合わせフォーム</a>
            からリクエストいただければ遅滞なく開示いたします。
          </li>
        </ul>
      </div>

      <p class="text-[#5A6B85] text-sm mt-12 pt-6 border-t border-[#D8DEE8]">制定日：{establishedDate}</p>
    </div>
  </div>
</BaseLayout>
