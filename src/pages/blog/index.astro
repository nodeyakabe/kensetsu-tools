---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const categories = [...new Set(allPosts.map(p => p.data.category).filter(Boolean))];
---

<BaseLayout
  title="ブログ"
  description="法令対応・確定申告・実務ノウハウなど、建設業の現場で役立つ情報をお届けします。"
>
  <div class="container-base py-16">
    <nav class="text-sm text-slate-500 mb-10" aria-label="パンくずリスト">
      <a href="/" class="hover:text-primary-600 transition-colors">ホーム</a>
      <span class="mx-2">/</span>
      <span class="text-slate-700">ブログ</span>
    </nav>

    <div class="mb-10">
      <h1 class="text-4xl font-bold text-primary-900 mb-3">ブログ</h1>
      <p class="text-slate-500 text-lg">法令対応・確定申告・実務ノウハウなど、現場で役立つ情報をお届けします。</p>
    </div>

    <!-- カテゴリフィルター -->
    {allPosts.length > 0 && (
      <div class="flex flex-wrap gap-3 mb-10" id="category-filter">
        <button
          class="filter-btn active h-11 px-5 rounded-lg text-sm font-bold border-2 transition-colors duration-150"
          data-category=""
          aria-pressed="true"
        >全て</button>
        {categories.map(cat => (
          <button
            class="filter-btn h-11 px-5 rounded-lg text-sm font-bold border-2 transition-colors duration-150"
            data-category={cat}
            aria-pressed="false"
          >{cat}</button>
        ))}
      </div>
    )}

    {allPosts.length === 0 ? (
      <div class="text-center py-24 text-slate-400">
        <div class="text-6xl mb-4" aria-hidden="true">📝</div>
        <p class="text-xl">記事を準備中です。しばらくお待ちください。</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="post-grid">
        {allPosts.map(post => (
          <div data-category={post.data.category ?? ''}>
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              publishedAt={post.data.publishedAt}
              category={post.data.category}
              tags={post.data.tags}
            />
          </div>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .filter-btn {
    background: white;
    color: #0F2557;
    border-color: #0F2557;
  }
  .filter-btn:hover {
    background: #EEF2FF;
  }
  .filter-btn.active {
    background: #F59E0B;
    color: white;
    border-color: #F59E0B;
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLDivElement>('#post-grid > div');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const selected = btn.dataset.category ?? '';

      buttons.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-pressed', 'false'); });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');

      cards.forEach(card => {
        const cat = card.dataset.category ?? '';
        card.style.display = (selected === '' || cat === selected) ? '' : 'none';
      });
    });
  });
</script>
