---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

const features = [
  {
    icon: '📋',
    title: '法令対応ツール',
    desc: '改正建設業法・労働安全衛生法など、2025年の法令改正に対応した書類・チェックリストを提供。',
  },
  {
    icon: '🔧',
    title: '業務テンプレート',
    desc: '見積書・工程表・日報・KY活動表など、現場で使えるテンプレートを無料で提供。すぐにダウンロード可能。',
  },
  {
    icon: '📖',
    title: '業界情報・ノウハウ',
    desc: '建設業の法改正・助成金・実務ノウハウをわかりやすく解説。一人親方・新規開業者に特に役立つ情報を発信。',
  },
];

const siteUrl = 'https://kensetsu-tools.com';
const orgSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: '建設業ツール工房',
  url: siteUrl,
  logo: `${siteUrl}/favicon.svg`,
  description: '建設業向けの業務ツール・テンプレート・業界情報を提供するサイトです。',
});
const websiteSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '建設業ツール工房',
  url: siteUrl,
});
---

<BaseLayout
  title="建設業ツール工房"
  description="建設業の現場を、もっとシンプルに。法令対応・業務ツール・テンプレート・業界情報を提供。一人親方・中小建設業・新規開業者向け。"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={orgSchema} />
    <script type="application/ld+json" set:html={websiteSchema} />
  </Fragment>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary-900 via-primary-800 to-primary-700 text-white overflow-hidden">
    <div class="container-base py-16 md:py-24">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">

        <!-- テキスト -->
        <div class="flex-1 min-w-0">
          <div class="inline-block bg-accent-500 text-white text-xs font-bold px-3 py-1 rounded-full mb-6 uppercase tracking-wider">
            建設業向け 無料ツール・情報サイト
          </div>
          <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-6">
            建設業の現場を、<br>
            <span class="text-accent-400">もっとシンプルに。</span>
          </h1>
          <p class="text-primary-200 text-lg leading-relaxed mb-10 max-w-2xl">
            法令対応・業務効率化のためのツールと知識を提供。<br>
            一人親方・中小建設業・新規開業者のための実務サポートサイトです。
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/blog/" class="btn-primary text-center">ブログを読む</a>
            <a href="/products/" class="inline-block border-2 border-white hover:bg-white text-white hover:text-primary-800 font-bold py-3 px-8 rounded-lg transition-colors duration-200 text-center">
              ツールを見る
            </a>
          </div>
        </div>

        <!-- マスコット（lg以上で表示） -->
        <!-- sheet-v2.jpg: 1024x1536px。左半分=ミケル、右半分=クロエ -->
        <!-- imgW=420 → xScale=420/1024≈0.41、yScale=630/1536≈0.41 -->
        <!-- キャラ本体: y=70〜640(原寸) → scaled top=-29 で上部テキストをスキップ -->
        <div class="hidden lg:flex items-end gap-6 flex-shrink-0">

          <!-- クロエ（左に配置） -->
          <div class="flex flex-col items-center gap-2">
            <div class="relative bg-white text-primary-900 text-xs font-bold rounded-2xl rounded-bl-none px-4 py-2 shadow-lg max-w-[130px] text-center leading-snug">
              お悩みは何でも<br>相談にゃ！
              <span class="absolute -bottom-2 left-4 w-3 h-3 bg-white rotate-45 border-b border-r border-white"></span>
            </div>
            <img
              src="/images/characters/kuroe_tati.png"
              alt="クロエ"
              loading="eager"
              style="width:130px;"
            />
            <p class="text-primary-300 text-xs font-semibold tracking-wide">クロエ</p>
          </div>

          <!-- ミケル（右・メイン） -->
          <div class="flex flex-col items-center gap-2">
            <div class="relative bg-accent-400 text-primary-900 text-xs font-bold rounded-2xl rounded-br-none px-4 py-2 shadow-lg max-w-[130px] text-center leading-snug">
              良い工具で仕事は<br>もっとはかどるにゃ！
              <span class="absolute -bottom-2 right-4 w-3 h-3 bg-accent-400 rotate-45"></span>
            </div>
            <img
              src="/images/characters/mikeru_tati.png"
              alt="ミケル"
              loading="eager"
              style="width:140px;"
            />
            <p class="text-primary-300 text-xs font-semibold tracking-wide">ミケル</p>
          </div>

        </div>
      </div>
    </div>
    <div class="h-12 bg-white" style="clip-path: ellipse(110% 100% at 50% 100%)"></div>
  </section>

  <!-- Features -->
  <section class="py-20">
    <div class="container-base">
      <div class="text-center mb-14">
        <h2 class="section-title">建設業ツール工房でできること</h2>
        <p class="section-subtitle">建設業の「あったらいいな」をまとめました</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {features.map(f => (
          <div class="card p-8 text-center">
            <div class="text-5xl mb-5">{f.icon}</div>
            <h3 class="font-bold text-xl text-primary-900 mb-3">{f.title}</h3>
            <p class="text-slate-600 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Target audience -->
  <section class="bg-primary-50 py-16">
    <div class="container-base">
      <div class="text-center mb-10">
        <h2 class="section-title">こんな方のためのサイトです</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
        {['一人親方・個人事業主', '建設業の中小企業', '建設業への新規参入者'].map(item => (
          <div class="flex items-center gap-3 bg-white rounded-xl px-6 py-4 shadow-sm border border-primary-100">
            <span class="text-accent-500 text-xl font-bold">✓</span>
            <span class="font-medium text-slate-800">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Recent Posts -->
  {posts.length > 0 && (
    <section class="py-20">
      <div class="container-base">
        <div class="flex items-end justify-between mb-10">
          <div>
            <h2 class="section-title mb-2">最新の記事</h2>
            <p class="text-slate-500">現場で役立つ情報を定期発信しています</p>
          </div>
          <a href="/blog/" class="text-primary-600 hover:text-primary-800 font-medium text-sm transition-colors hidden sm:block">
            すべての記事を見る →
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {posts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              publishedAt={post.data.publishedAt}
              category={post.data.category}
              tags={post.data.tags}
              heroImage={post.data.heroImage}
            />
          ))}
        </div>
        <div class="text-center mt-10 sm:hidden">
          <a href="/blog/" class="btn-outline">すべての記事を見る</a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-primary-900 text-white py-20">
    <div class="container-base text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        まずはブログから読んでみてください
      </h2>
      <p class="text-primary-200 text-lg mb-10 max-w-2xl mx-auto">
        建設業の実務に役立つノウハウを、わかりやすい言葉でお届けしています。
      </p>
      <a href="/blog/" class="inline-block bg-accent-500 hover:bg-accent-600 text-white font-bold py-3 px-8 rounded-lg transition-colors duration-200">
        ブログを読む →
      </a>
    </div>
  </section>
</BaseLayout>
