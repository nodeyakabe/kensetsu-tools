---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { PRODUCT } from '@/data/product';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

const painItems = [
  { title: '確定申告・帳簿づけが毎年憂うつ',   desc: 'レシートと請求書の山を前に、毎年2月が近づくと気が重い。' },
  { title: '書類づくりに時間がとられる',         desc: '見積・請求・安全書類。現場を終えた夜に事務仕事が残っている。' },
  { title: '専用ソフトは高いし、難しそう',       desc: '機能が多すぎて使いこなせる気がしない。導入の手間も心配。' },
  { title: '月額サブスクを増やしたくない',       desc: '使うのは月に数回なのに、固定費がじわじわ積み上がる。' },
  { title: 'そもそもITが苦手',                  desc: 'パソコンは得意じゃない。何から手をつければいいか分からない。' },
];

const targetTypes = [
  { tag: 'ひとりで全部',  title: '一人親方・個人事業主の方',    desc: '現場も事務もぜんぶ自分。確定申告や帳簿づけにかける時間を、できるだけ短くしたい方に。' },
  { tag: '〜10人の会社',  title: '中小建設業の方',              desc: '高機能なシステムを入れるほどではない。でも紙とカンだけの管理から、一歩進みたい方に。' },
  { tag: '独立したて',    title: 'これから建設業をはじめる方',   desc: '新規参入したばかりで、お金と書類のことが不安。最初のひとそろえを探している方に。' },
];

const pillars = [
  { num: '1', title: '法令対応ツール',   desc: '確定申告やインボイスなど、制度にきちんと対応した実務ツール。買い切りで、ずっと使えます。' },
  { num: '2', title: '業務テンプレート', desc: '見積書・請求書・安全書類など、現場でそのまま使えるひな形。書類づくりの時間を減らします。' },
  { num: '3', title: '業界情報',         desc: '制度改正や実務のコツを、専門用語をかみくだいて解説。ブログで無料で読めます。' },
];

const productHighlights = [
  'Excelだけで動く（マクロなし・警告なし）',
  '工事ごとの収支を自動集計',
  '確定申告用サマリーを出力',
  '説明書いらずのシンプル設計',
];

---

<BaseLayout
  title="建設業ツール工房"
  description="建設業の現場を、もっとシンプルに。一人親方・小規模建設業のための買い切り業務ツールと実務情報。確定申告・書類づくりをExcelでシンプルに。"
>

<!-- ===== 1. ヒーロー（ファーストビュー: LCP保護のためreveal対象外） ===== -->
<section class="bg-[#EFF2F7]">
  <div class="max-w-[1160px] mx-auto px-4 sm:px-6 lg:px-8 pt-10 sm:pt-12 pb-0">

    <!-- 全幅ネイビーカード — タイトルを主役に -->
    <div class="bg-[#0F2557] rounded-3xl px-8 py-12 sm:px-12 sm:py-14">
      <div class="flex flex-col lg:flex-row lg:items-end gap-8 lg:gap-14">

        <!-- テキストブロック（主役） -->
        <div class="flex-1 flex flex-col gap-6">
          <div class="flex items-center gap-2.5">
            <span class="w-2 h-2 bg-[#F59E0B] rounded-full flex-shrink-0"></span>
            <span class="text-[12.5px] font-bold tracking-widest text-[#F59E0B]">一人親方・小規模建設業のための業務ツール</span>
          </div>
          <h1 class="text-4xl sm:text-5xl font-black leading-[1.35] text-white tracking-wide">
            建設業の現場を、<br class="hidden sm:block">もっとシンプルに。
          </h1>
          <p class="text-[15px] leading-[2] text-[#C7D2E5] max-w-[560px]">
            買い切り（月額なし）の業務ツールと実務情報。むずかしい操作はありません。ITが苦手な方でも、今日から使えます。
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/products/" class="bg-[#F59E0B] hover:bg-[#D98908] text-white font-bold text-[15px] px-7 py-3.5 rounded-full text-center btn-press">ツール・商品を見る</a>
            <a href="/blog/" class="border border-[#4A5E8C] hover:border-white text-white font-bold text-[15px] px-7 py-3.5 rounded-full text-center transition-colors">ブログを読む</a>
          </div>
          <!-- 信頼チップ -->
          <div class="flex flex-wrap gap-2 pt-5 mt-auto border-t border-[#2A4374]">
            {[
              '買い切り・月額なし',
              'マクロなしのExcel',
              '確定申告に対応',
            ].map(chip => (
              <div class="bg-[#1B3463] rounded-full px-4 py-1.5 text-[12.5px] font-bold text-[#C7D2E5] flex items-center gap-1.5">
                <span class="text-[#F59E0B]">✓</span>{chip}
              </div>
            ))}
          </div>
        </div>

        <!-- マスコット（小さな脇役、PCのみ） -->
        <div class="hidden lg:flex flex-col items-center gap-3 flex-shrink-0">
          <div class="flex gap-4 items-end">
            <!-- ウタ -->
            <div class="flex flex-col items-center gap-1.5">
              <div class="w-[88px] h-[88px] bg-[#1B3463] rounded-full overflow-hidden flex items-center justify-center">
                <img
                  src="/images/characters/uta_tati.png"
                  alt="黒猫のウタ"
                  width="88"
                  height="88"
                  class="w-full h-full object-contain mascot-idle"
                  loading="eager"
                />
              </div>
              <span class="text-[11px] font-bold text-[#8FA1C4]">ウタ</span>
            </div>
            <!-- ナツ -->
            <div class="flex flex-col items-center gap-1.5">
              <div class="w-[88px] h-[88px] bg-[#1B3463] rounded-full overflow-hidden flex items-center justify-center">
                <img
                  src="/images/characters/natu_tati.png"
                  alt="三毛猫のナツ"
                  width="88"
                  height="88"
                  class="w-full h-full object-contain mascot-idle"
                  loading="eager"
                  style="animation-delay: 0.9s;"
                />
              </div>
              <span class="text-[11px] font-bold text-[#8FA1C4]">ナツ</span>
            </div>
          </div>
          <span class="text-[11px] text-[#5A6B85]">工房の案内係</span>
        </div>

      </div>
    </div>
  </div>

  <!-- ラインナップ帯 -->
  <div class="max-w-[1160px] mx-auto px-4 sm:px-6 lg:px-8 pt-5 pb-10 sm:pb-12">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-5 reveal-stagger">

      <!-- 第1弾・発売中 -->
      <a href="/products/koji-daicho/" class="reveal group bg-white border border-[#D8DEE8] hover:border-[#0F2557] rounded-2xl p-5 sm:p-6 flex flex-col gap-2 no-underline text-inherit" style="transition:border-color 0.2s ease,transform 0.2s ease,box-shadow 0.2s ease;">
        <div>
          <span class="bg-[#F59E0B] text-white text-[11px] font-bold px-3 py-0.5 rounded-full">第1弾・発売中</span>
        </div>
        <div class="text-base font-black text-[#0F2557]">シンプル工事台帳 ライト版</div>
        <div class="flex items-center justify-between">
          <div class="text-[12.5px] text-[#5A6B85]">確定申告用の収支管理（Excel）</div>
          <div class="text-sm font-black text-[#0F2557]">¥{PRODUCT.price.toLocaleString()}</div>
        </div>
      </a>

      <!-- 第2弾・準備中 -->
      <a href="/products/" class="reveal group bg-white border border-dashed border-[#B9C4D6] hover:border-[#0F2557] rounded-2xl p-5 sm:p-6 flex flex-col gap-2 no-underline text-inherit" style="transition:border-color 0.2s ease,transform 0.2s ease,box-shadow 0.2s ease;">
        <div>
          <span class="border border-[#5A6B85] text-[#5A6B85] text-[11px] font-bold px-3 py-0.5 rounded-full">第2弾・準備中</span>
        </div>
        <div class="text-base font-black text-[#0F2557]">シンプル安全台帳</div>
        <div class="text-[12.5px] text-[#5A6B85]">資格・車両の期限管理＋安全書類</div>
      </a>

      <!-- 第3弾・構想中 -->
      <a href="/contact/" class="reveal group bg-white border border-dashed border-[#B9C4D6] hover:border-[#0F2557] rounded-2xl p-5 sm:p-6 flex flex-col gap-2 no-underline text-inherit" style="transition:border-color 0.2s ease,transform 0.2s ease,box-shadow 0.2s ease;">
        <div>
          <span class="border border-[#5A6B85] text-[#5A6B85] text-[11px] font-bold px-3 py-0.5 rounded-full">第3弾・構想中</span>
        </div>
        <div class="text-base font-black text-[#0F2557]">次の道具は、現場の声から</div>
        <div class="text-[12.5px] text-[#5A6B85]">「こんな道具がほしい」をお聞かせください →</div>
      </a>

    </div>
  </div>
</section>


<!-- ===== 2. こんなお悩み ===== -->
<section class="bg-white">
  <div class="max-w-[1160px] mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 flex flex-col gap-9 reveal">
    <div class="flex items-center gap-4">
      <div class="w-11 h-11 bg-[#0F2557] rounded-full text-white font-mono text-[13px] flex items-center justify-center flex-shrink-0">01</div>
      <h2 class="text-2xl sm:text-[28px] font-black text-[#0F2557]">こんなお悩み、ありませんか？</h2>
    </div>
    <div class="border border-[#D8DEE8] rounded-2xl overflow-hidden">
      {painItems.map((item, i) => (
        <div class={`flex items-start sm:items-center gap-4 sm:gap-5 px-5 sm:px-[30px] py-4 sm:py-[19px] ${i < painItems.length - 1 ? 'border-b border-[#E9EDF3]' : ''} ${i % 2 === 1 ? 'bg-[#FAFBFD]' : ''}`}>
          <div class="w-[30px] h-[30px] bg-[#FDEBC8] rounded-full text-[#B45309] font-mono text-xs flex items-center justify-center flex-shrink-0 mt-0.5 sm:mt-0">{i + 1}</div>
          <div class="flex flex-col sm:flex-row sm:items-center sm:gap-5 gap-1 min-w-0">
            <div class="text-[15px] sm:text-[15.5px] font-bold flex-none sm:w-[300px]">{item.title}</div>
            <div class="text-[13px] text-[#5A6B85]">{item.desc}</div>
          </div>
        </div>
      ))}
      <div class="bg-[#0F2557] px-5 sm:px-[30px] py-4 text-sm font-bold text-white flex items-center gap-2.5">
        <span class="w-2 h-2 bg-[#F59E0B] rounded-full flex-shrink-0"></span>
        ひとつでも当てはまった方のために、このサイトをつくりました。
      </div>
    </div>
  </div>
</section>


<!-- ===== 3. こんな方のためのサイト ===== -->
<section id="about" class="bg-[#EFF2F7]">
  <div class="max-w-[1160px] mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 flex flex-col gap-9">
    <div class="flex items-center gap-4 reveal">
      <div class="w-11 h-11 bg-[#0F2557] rounded-full text-white font-mono text-[13px] flex items-center justify-center flex-shrink-0">02</div>
      <h2 class="text-2xl sm:text-[28px] font-black text-[#0F2557]">こんな方のためのサイトです</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 reveal-stagger">
      {targetTypes.map(t => (
        <div class="reveal bg-white rounded-2xl p-7 flex flex-col gap-3">
          <span class="self-start bg-[#EFF2F7] text-[#0F2557] text-[11.5px] font-bold px-3.5 py-1 rounded-full">{t.tag}</span>
          <div class="text-[17px] font-black text-[#0F2557]">{t.title}</div>
          <div class="text-[13.5px] leading-[1.9] text-[#44536E]">{t.desc}</div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ===== 4. できること（3本柱） ===== -->
<section class="bg-white">
  <div class="max-w-[1160px] mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 flex flex-col gap-9">
    <div class="flex items-center gap-4 reveal">
      <div class="w-11 h-11 bg-[#0F2557] rounded-full text-white font-mono text-[13px] flex items-center justify-center flex-shrink-0">03</div>
      <h2 class="text-2xl sm:text-[28px] font-black text-[#0F2557]">建設業ツール工房でできること</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 reveal-stagger">
      {pillars.map(p => (
        <div class="reveal border border-[#D8DEE8] rounded-2xl p-8 flex flex-col gap-3" style="transition:box-shadow 0.2s ease,transform 0.2s ease;">
          <div class="w-9 h-9 bg-[#F59E0B] rounded-full text-white font-mono text-[13px] flex items-center justify-center flex-shrink-0">{p.num}</div>
          <div class="text-[18px] font-black text-[#0F2557]">{p.title}</div>
          <div class="text-[13.5px] leading-[1.9] text-[#5A6B85]">{p.desc}</div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ===== 5. 注目の商品 ===== -->
<section id="products" class="bg-[#EFF2F7]">
  <div class="max-w-[1160px] mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 flex flex-col gap-9">
    <div class="flex items-center gap-4 reveal">
      <div class="w-11 h-11 bg-[#0F2557] rounded-full text-white font-mono text-[13px] flex items-center justify-center flex-shrink-0">04</div>
      <h2 class="text-2xl sm:text-[28px] font-black text-[#0F2557]">注目の商品</h2>
    </div>

    <div class="bg-white rounded-3xl p-8 sm:p-12 relative reveal">
      <!-- バッジ -->
      <div class="sm:absolute sm:top-9 sm:right-11 inline-block sm:hidden bg-[#F59E0B] text-white text-[13px] font-black px-5 py-2 rounded-full mb-6">第1弾・発売中</div>
      <div class="hidden sm:block absolute top-9 right-11 bg-[#F59E0B] text-white text-[13px] font-black px-5 py-2 rounded-full rotate-[4deg]">第1弾・発売中</div>

      <div class="flex flex-col lg:flex-row gap-10 lg:gap-14">
        <!-- 左：説明 -->
        <div class="flex-[1.2] flex flex-col gap-4 sm:gap-[18px]">
          <h3 class="text-2xl sm:text-[26px] font-black text-[#0F2557]">{PRODUCT.name}</h3>
          <p class="text-[14.5px] leading-[1.9] text-[#44536E]">
            工事ごとの入金と支出を入力するだけで、確定申告に使える収支がまとまる、Excelの工事台帳です。むずかしい設定や説明書は要りません。
          </p>
          <ul class="flex flex-col gap-2.5">
            {productHighlights.map(h => (
              <li class="flex items-center gap-2.5 text-sm">
                <span class="text-[#F59E0B] font-black flex-shrink-0">✓</span>{h}
              </li>
            ))}
          </ul>
          <div class="flex items-center gap-4 mt-1.5">
            <a href={PRODUCT.slug} class="bg-[#F59E0B] hover:bg-[#D98908] text-white font-bold text-[15px] px-8 py-3.5 rounded-full btn-press">商品ページを見る</a>
            <div class="text-[12.5px] text-[#5A6B85]">追加費用・更新料はありません</div>
          </div>
        </div>

        <!-- 右：SPEC表 -->
        <div class="flex-1 flex flex-col gap-3.5 justify-center">
          <div class="font-mono text-[11px] tracking-widest text-[#8FA1C4]">SPEC — 仕様</div>
          <div class="border border-[#D8DEE8] rounded-2xl overflow-hidden">
            <div class="grid grid-cols-[100px_1fr] sm:grid-cols-[120px_1fr] text-[13px]">
              <div class="px-4 sm:px-5 py-3 bg-[#EFF2F7] font-bold text-[#0F2557] border-b border-[#E3E8F0]">価格</div>
              <div class="px-4 sm:px-5 py-3 border-b border-[#E9EDF3] flex items-baseline gap-2">
                <span class="text-[20px] font-black text-[#0F2557]">¥{PRODUCT.price.toLocaleString()}</span>
                <span class="text-xs text-[#5A6B85]">税込</span>
              </div>
              <div class="px-4 sm:px-5 py-3 bg-[#EFF2F7] font-bold text-[#0F2557] border-b border-[#E3E8F0]">販売形態</div>
              <div class="px-4 sm:px-5 py-3 border-b border-[#E9EDF3] text-[#44536E]">買い切り（月額・更新料なし）</div>
              <div class="px-4 sm:px-5 py-3 bg-[#EFF2F7] font-bold text-[#0F2557] border-b border-[#E3E8F0]">形式</div>
              <div class="px-4 sm:px-5 py-3 border-b border-[#E9EDF3] text-[#44536E]">Excel（.xlsx）／マクロ不使用</div>
              <div class="px-4 sm:px-5 py-3 bg-[#EFF2F7] font-bold text-[#0F2557] border-b border-[#E3E8F0]">用途</div>
              <div class="px-4 sm:px-5 py-3 border-b border-[#E9EDF3] text-[#44536E]">工事ごとの収支管理・確定申告の準備</div>
              <div class="px-4 sm:px-5 py-3 bg-[#EFF2F7] font-bold text-[#0F2557]">サポート</div>
              <div class="px-4 sm:px-5 py-3 text-[#44536E]">お問い合わせフォームにて対応</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ===== 6. 今後のラインナップ ===== -->
<section id="roadmap" class="bg-white">
  <div class="max-w-[1160px] mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 flex flex-col gap-9">
    <div class="flex items-center gap-4 reveal">
      <div class="w-11 h-11 bg-[#0F2557] rounded-full text-white font-mono text-[13px] flex items-center justify-center flex-shrink-0">05</div>
      <h2 class="text-2xl sm:text-[28px] font-black text-[#0F2557]">今後のラインナップ</h2>
    </div>
    <div class="border border-dashed border-[#B9C4D6] rounded-3xl p-8 sm:p-10 sm:px-12 flex flex-col sm:flex-row items-start sm:items-center gap-8 sm:gap-11 reveal">
      <div class="flex-1 flex flex-col gap-3">
        <div class="flex flex-wrap gap-2 items-center">
          <span class="border border-[#5A6B85] text-[#5A6B85] text-xs font-bold px-3.5 py-0.5 rounded-full">準備中</span>
          <span class="border border-[#0F2557] text-[#0F2557] text-xs font-bold px-3.5 py-0.5 rounded-full">第2弾</span>
        </div>
        <h3 class="text-xl sm:text-[22px] font-black text-[#0F2557]">シンプル安全台帳</h3>
        <p class="text-sm leading-[1.9] text-[#5A6B85] max-w-[620px]">
          作業員の資格・健康診断、車両の車検・保険といった「期限もの」をひと目で管理し、安全書類づくりまでつなげるツールです。発売時期が決まりましたら、ブログとお知らせでご案内します。
        </p>
      </div>
      <a href="/blog/" class="flex-none border border-[#0F2557] text-[#0F2557] hover:bg-[#0F2557] hover:text-white font-bold text-sm px-6 py-3 rounded-full transition-colors whitespace-nowrap">お知らせを待つ →</a>
    </div>
  </div>
</section>


<!-- ===== 7. 最新の記事 ===== -->
<section id="blog" class="bg-[#EFF2F7]">
  <div class="max-w-[1160px] mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 flex flex-col gap-9">
    <div class="flex items-center gap-4 reveal">
      <div class="w-11 h-11 bg-[#0F2557] rounded-full text-white font-mono text-[13px] flex items-center justify-center flex-shrink-0">06</div>
      <h2 class="text-2xl sm:text-[28px] font-black text-[#0F2557]">最新の記事</h2>
      <a href="/blog/" class="ml-auto text-sm font-bold text-[#0F2557] hover:underline transition-colors whitespace-nowrap hidden sm:block">記事一覧を見る →</a>
    </div>

    {posts.length > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 reveal-stagger">
        {posts.map(post => (
          <a
            href={`/blog/${post.slug}/`}
            class="reveal group bg-white rounded-2xl p-6 sm:p-7 flex flex-col gap-3 no-underline text-inherit hover-lift"
            style="transition:box-shadow 0.2s ease,transform 0.2s ease,outline-color 0.2s ease;"
          >
            <div class="flex gap-2.5 items-center text-xs text-[#5A6B85]">
              {post.data.category && (
                <span class="bg-[#EFF2F7] rounded-full px-3 py-0.5 font-bold text-[#0F2557]">{post.data.category}</span>
              )}
              <span class="font-mono">
                {post.data.publishedAt.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '.')}
              </span>
            </div>
            <div class="text-[15px] font-bold leading-[1.7] text-[#0F2557]">{post.data.title}</div>
            <div class="text-[13px] font-bold text-[#F59E0B] mt-auto">読む →</div>
          </a>
        ))}
      </div>
    )}

    <!-- モバイル用「記事一覧を見る」 -->
    <div class="sm:hidden text-center">
      <a href="/blog/" class="text-sm font-bold text-[#0F2557] hover:underline">記事一覧を見る →</a>
    </div>

    <!-- お客様の声（準備中） -->
