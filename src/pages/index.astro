---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogCard from '@/components/BlogCard.astro';
import ComingSoonCard from '@/components/ComingSoonCard.astro';
import { comingSoonItems } from '@/data/coming-soon';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

const features = [
  {
    icon: '📋',
    title: '法令対応ツール',
    desc: '改正建設業法・労働安全衛生法など、最新の法令改正に対応した書類・チェックリストを提供。',
  },
  {
    icon: '🔧',
    title: '業務テンプレート',
    desc: '見積書・工程表・日報・KY活動表など、現場で使えるテンプレートを順次提供予定です。',
  },
  {
    icon: '📖',
    title: '業界情報・ノウハウ',
    desc: '建設業の法改正・助成金・実務ノウハウをわかりやすく解説。一人親方・新規開業者に特に役立つ情報を発信。',
  },
];
---

<BaseLayout
  title="建設業ツール工房"
  description="建設業の現場を、もっとシンプルに。法令対応・業務ツール・テンプレート・業界情報を提供。一人親方・中小建設業・新規開業者向け。"
>
  <!-- ヒーロー -->
  <section class="bg-gradient-to-br from-primary-900 via-primary-800 to-primary-700 text-white overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-24">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-6">

        <!-- テキスト -->
        <div class="flex-1 min-w-0 pl-6 lg:pl-12">
          <div class="inline-block bg-accent-500 text-white text-sm font-bold px-3 py-1 rounded-full mb-6 uppercase tracking-wider">
            建設業向け 業務ツール・情報サイト
          </div>
          <h1 class="text-4xl lg:text-5xl font-bold leading-tight mb-6 lg:whitespace-nowrap">
            建設業の現場を、<br>
            <span class="text-accent-400">もっとシンプルに。</span>
          </h1>
          <p class="text-primary-200 text-xl leading-relaxed mb-10 max-w-2xl">
            一人親方・小規模建設業のための、買い切りの業務ツールと、<br class="hidden md:inline">
            法令・実務の情報をお届けします。
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/products/" class="inline-block bg-accent-500 hover:bg-accent-600 text-white font-bold py-3 px-8 rounded-lg transition-colors duration-200 text-center">ツール・商品を見る</a>
            <a href="/blog/" class="inline-block border-2 border-white hover:bg-white text-white hover:text-primary-800 font-bold py-3 px-8 rounded-lg transition-colors duration-200 text-center">
              ブログを読む
            </a>
          </div>
        </div>

        <!-- マスコット（lg以上で表示） -->
        <div class="hidden lg:flex items-end gap-4 flex-shrink-0 -mr-6">

          <!-- ウタ（左） -->
          <div class="flex flex-col items-center gap-2 self-end">
            <div class="relative bg-white text-primary-900 text-xs font-bold rounded-2xl rounded-bl-none px-4 py-2 shadow-lg max-w-[150px] text-center leading-snug">
              複雑な作業は、不要です。
              <span class="absolute -bottom-2 left-4 w-3 h-3 bg-white rotate-45"></span>
            </div>
            <img
              src="/images/characters/uta_tati.png"
              alt="ウタ"
              loading="eager"
              width="147"
              height="220"
              class="drop-shadow-lg"
              style="height:220px; width:auto;"
            />
          </div>

          <!-- ナツ（右・メイン） -->
          <div class="flex flex-col items-center gap-2 self-end">
            <div class="relative bg-accent-400 text-primary-900 text-xs font-bold rounded-2xl rounded-br-none px-4 py-2 shadow-lg max-w-[160px] text-center leading-snug">
              いいツールで、仕事はもっとはかどります。
              <span class="absolute -bottom-2 right-4 w-3 h-3 bg-accent-400 rotate-45"></span>
            </div>
            <img
              src="/images/characters/natu_tati.png"
              alt="ナツ"
              loading="eager"
              width="187"
              height="240"
              class="drop-shadow-lg"
              style="height:240px; width:auto;"
            />
          </div>

        </div>
      </div>
    </div>
    <div class="h-12 bg-white" style="clip-path: ellipse(110% 100% at 50% 100%)"></div>
  </section>

  <!-- できること（3本柱）- ヒーロー直下 -->
  <section class="py-16 bg-white">
    <div class="container-base">
      <div class="text-center mb-12">
        <h2 class="section-title">建設業ツール工房でできること</h2>
        <p class="section-subtitle">建設業の「あったらいいな」をまとめました</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {features.map(f => (
          <div class="card p-8 text-center">
            <div class="text-5xl mb-5" aria-hidden="true">{f.icon}</div>
            <h3 class="font-bold text-xl text-primary-900 mb-3">{f.title}</h3>
            <p class="text-slate-600 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 注目の商品（第1弾） -->
  <section class="py-16 bg-slate-50">
    <div class="container-base">
      <div class="text-center mb-10">
        <h2 class="section-title">注目の商品</h2>
        <p class="section-subtitle">現在発売中の第1弾ツールです</p>
      </div>
      <div class="max-w-2xl mx-auto bg-white border-2 border-accent-400 rounded-xl p-8 shadow-md">
        <div class="mb-4 flex items-center gap-3">
          <span class="inline-block bg-accent-500 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">発売中</span>
          <span class="text-slate-400 text-xs font-medium">第1弾</span>
        </div>
        <h3 class="text-2xl font-bold text-primary-900 mb-2">シンプル工事台帳 ライト版</h3>
        <p class="text-accent-500 font-semibold mb-1">¥5,980</p>
        <p class="text-slate-500 text-sm mb-6">税込・買い切り</p>
        <ul class="space-y-3 mb-8">
          {[
            'Excelだけで動く。特別なソフト不要。',
            '工事ごとの収支を自動集計。',
            '確定申告に使える収支サマリーを出力。',
            '一人親方・小規模事業者向けのシンプル設計。',
          ].map(item => (
            <li class="flex items-start gap-3">
              <span class="text-accent-500 font-bold mt-0.5 flex-shrink-0">✓</span>
              <span class="text-slate-700">{item}</span>
            </li>
          ))}
        </ul>
        <a href="/products/koji-daicho/" class="inline-block bg-accent-500 hover:bg-accent-600 text-white font-bold py-3 px-6 rounded-lg transition-colors text-sm">
          商品の詳細・購入はこちら →
        </a>
      </div>
    </div>
  </section>

  <!-- 悩みセクション -->
  <section class="py-20 bg-white">
    <div class="container-base max-w-2xl mx-auto">
      <h2 class="section-title mb-12">こんな悩みありませんか？</h2>
      <ul class="space-y-5 mb-10">
        {[
          '工事ごとの利益が見えない',
          '確定申告の準備が毎年地獄',
          'Excelファイルがバラバラに散らばる',
          'サブスクの月額負担がしんどい',
        ].map(item => (
          <li class="flex items-center gap-4 text-lg text-slate-700">
            <span class="text-red-400 font-black text-xl flex-shrink-0" aria-hidden="true">!</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
      <p class="text-slate-500 text-sm text-center">
        そんな悩みを解決するツールがあります。<br>
        <a href="/products/koji-daicho/" class="text-primary-600 hover:text-primary-800 font-semibold transition-colors">
          「シンプル工事台帳」の詳細を見る →
        </a>
      </p>
    </div>
  </section>

  <!-- 今後のラインナップ（準備中） -->
  <section class="py-16 bg-slate-50">
    <div class="container-base">
      <div class="text-center mb-10">
        <h2 class="section-title">今後のラインナップ</h2>
        <p class="section-subtitle">順次提供予定です（提供時期は未定）</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl mx-auto">
        {comingSoonItems.map(card => (
          <ComingSoonCard title={card.title} desc={card.desc} />
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/products/" class="text-primary-600 hover:text-primary-800 font-semibold transition-colors text-sm">
          すべてのツールを見る →
        </a>
      </div>
    </div>
  </section>

  <!-- こんな方のためのサイトです -->
  <section class="bg-primary-50 py-16">
    <div class="container-base">
      <div class="text-center mb-10">
        <h2 class="section-title">こんな方のためのサイトです</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
        {['一人親方・個人事業主', '建設業の中小企業', '建設業への新規参入者'].map(item => (
          <div class="flex items-center gap-3 bg-white rounded-xl px-6 py-4 shadow-sm border border-primary-100">
            <span class="text-accent-500 text-xl font-bold">✓</span>
            <span class="font-medium text-slate-800">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 最新の記事 -->
  {posts.length > 0 && (
    <section class="py-20">
      <div class="container-base">
        <div class="flex items-end justify-between mb-10">
          <div>
            <h2 class="section-title mb-2">最新の記事</h2>
            <p class="text-slate-500">現場で役立つ情報を定期発信しています</p>
          </div>
          <a href="/blog/" class="text-primary-600 hover:text-primary-800 font-medium text-sm transition-colors hidden sm:block">
            すべての記事を見る →
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {posts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              publishedAt={post.data.publishedAt}
              category={post.data.category}
              tags={post.data.tags}
            />
          ))}
        </div>
        <div class="text-center mt-10 sm:hidden">
          <a href="/blog/" class="btn-outline">すべての記事を見る</a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-primary-900 text-white py-20">
    <div class="container-base text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        シンプル工事台帳 ライト版、好評発売中
      </h2>
      <p class="text-primary-200 text-lg mb-8 max-w-2xl mx-auto">
        個人事業主・一人親方向けのExcel工事管理ツール。マクロなし、<br>
        ¥5,980（税込・買い切り）。
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
        <a href="/products/koji-daicho/" class="inline-block bg-accent-500 hover:bg-accent-600 text-white font-bold py-3 px-8 rounded-lg transition-colors duration-200">
          商品の詳細・購入はこちら →
        </a>
      </div>
      <a href="/blog/" class="text-primary-300 hover:text-white text-sm transition-colors">
        ブログを読む →
      </a>
    </div>
  </section>
</BaseLayout>
