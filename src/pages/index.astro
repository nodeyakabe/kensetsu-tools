---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { PRODUCT } from '@/data/product';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

const painItems = [
  { title: '確定申告・帳簿づけが毎年憂うつ',   desc: 'レシートと請求書の山を前に、2月が近づくと気が重い。' },
  { title: '書類づくりに時間がとられる',         desc: '見積・請求・安全書類。現場を終えた夜に事務仕事が残る。' },
  { title: '専用ソフトは高いし、難しそう',       desc: '機能が多すぎて使いこなせる気がしない。導入の手間も心配。' },
  { title: '月額サブスクを増やしたくない',       desc: '使うのは月に数回なのに、固定費がじわじわ積み上がる。' },
  { title: 'そもそもITが苦手',                  desc: 'パソコンは得意じゃない。何から手をつければいいのか。' },
];

const targetTypes = [
  { tag: 'ひとりで全部', title: '一人親方・個人事業主の方',   desc: '現場も事務もぜんぶ自分。確定申告や帳簿づけにかける時間を、できるだけ短くしたい方に。' },
  { tag: '〜10人の会社', title: '中小建設業の方',             desc: '高機能なシステムを入れるほどではない。でも紙とカンだけの管理から、一歩進みたい方に。' },
  { tag: '独立したて',   title: 'これから建設業をはじめる方', desc: '新規参入したばかりで、お金と書類のことが不安。最初のひとそろえを探している方に。' },
];

const pillars = [
  { num: '01', title: '法令対応ツール',   desc: '確定申告やインボイスなど、制度にきちんと対応した実務ツール。買い切りで、ずっと使えます。' },
  { num: '02', title: '業務テンプレート', desc: '見積書・請求書・安全書類など、現場でそのまま使えるひな形。書類づくりの時間を減らします。' },
  { num: '03', title: '業界情報',         desc: '制度改正や実務のコツを、専門用語をかみくだいて解説。ブログで無料で読めます。' },
];

---

<BaseLayout
  title="建設業ツール工房"
  description="建設業の現場を、もっとシンプルに。一人親方・小規模建設業のための買い切り業務ツールと実務情報。確定申告・書類づくりをExcelでシンプルに。"
>


<!-- ===== S1. ヒーロー ===== -->
<section class="relative overflow-clip" style="background:#0F2557;">

  <!-- 装飾リング右上 -->
  <div
    class="hidden lg:block absolute pointer-events-none"
    aria-hidden="true"
    style="top:-120px; right:-160px; width:680px; height:680px; border:60px solid rgba(20,48,95,0.45); border-radius:50%; z-index:0;"
  ></div>

  <!-- 装飾リング左下 -->
  <div
    class="hidden lg:block absolute pointer-events-none"
    aria-hidden="true"
    style="bottom:-80px; left:-100px; width:360px; height:360px; border:40px solid rgba(20,48,95,0.3); border-radius:50%; z-index:0;"
  ></div>

  <!-- 左マージンキャラクター（ウタ） -->
  <img
    src="/images/characters/uta_product.png"
    aria-hidden="true"
    width="220"
    height="220"
    loading="lazy"
    class="hidden 2xl:block absolute pointer-events-none"
    style="left:20px; bottom:40px; width:220px; z-index:2;"
  />
  <!-- 右マージンキャラクター（ナツ） -->
  <img
    src="/images/characters/natu_product.png"
    aria-hidden="true"
    width="220"
    height="220"
    loading="lazy"
    class="hidden 2xl:block absolute pointer-events-none"
    style="right:20px; bottom:40px; width:220px; z-index:2;"
  />

  <!-- ブランドロゴ透かし（右端・文字にかぶる） -->
  <img
    src="/images/brand-watermark.png"
    aria-hidden="true"
    class="hidden lg:block absolute pointer-events-none select-none"
    style="left:1100px; top:38%; transform:translateY(-50%); width:500px; height:500px; object-fit:contain; opacity:0.12; z-index:2;"
  />

  <div class="max-w-[1350px] mx-auto px-4 sm:px-6 lg:px-10 pt-16 sm:pt-24 lg:pt-28 pb-14 sm:pb-16 lg:pb-20 relative flex flex-col gap-8 min-h-[520px] lg:min-h-[600px] justify-center" style="z-index:3;">

    <!-- メインコピー -->
    <div class="flex flex-col gap-7">

      <!-- バッジ -->
      <span
        class="inline-block font-bold self-start"
        style="color:#FFFFFF; font-size:17px; font-weight:700;"
      >● 一人親方・小規模建設業のための業務ツール</span>

      <!-- h1 -->
      <h1 class="text-[30px] sm:text-[46px] lg:text-[62px] font-black text-white" style="line-height:1.3; letter-spacing:0.04em;">
        建設業の現場を、もっと<span class="text-[38px] sm:text-[58px] lg:text-[78px]" style="color:#F59E0B; line-height:1.3; vertical-align:baseline;">シンプル</span>に。
      </h1>

      <!-- サブコピー -->
      <p style="font-size:16px; line-height:2.1; color:#C7D2E5; letter-spacing:0.04em;">
        買い切り（月額なし）の業務ツールと実務情報。むずかしい操作はありません。<br>ITが苦手な方でも、今日から使えます。
      </p>

    </div>

    <!-- 全幅トラストバー（工房の強み） -->
    <div class="bg-white rounded-2xl grid grid-cols-2 sm:grid-cols-4 mt-10" style="box-shadow:0 4px 24px rgba(0,0,0,0.15);">

      <div class="flex items-center gap-4 px-7 py-5 border-r border-b sm:border-b-0 border-[#E9EDF3]">
        <div aria-hidden="true" class="w-11 h-11 bg-[#EFF2F7] rounded-lg flex items-center justify-center text-[#0F2557] font-black text-[18px] flex-shrink-0">¥</div>
        <div>
          <div class="text-[14px] font-black text-[#0F2557]">買い切り・月額なし</div>
          <div class="text-[12px] text-[#5A6B85] mt-0.5">更新料も0円</div>
        </div>
      </div>

      <div class="flex items-center gap-4 px-7 py-5 border-b sm:border-b-0 sm:border-r border-[#E9EDF3]">
        <div aria-hidden="true" class="w-11 h-11 bg-[#EFF2F7] rounded-lg flex items-center justify-center text-[#0F2557] font-black text-[13px] flex-shrink-0">楽</div>
        <div>
          <div class="text-[14px] font-black text-[#0F2557]">説明書いらず</div>
          <div class="text-[12px] text-[#5A6B85] mt-0.5">開いてすぐ使える</div>
        </div>
      </div>

      <div class="flex items-center gap-4 px-7 py-5 border-r border-[#E9EDF3]">
        <div aria-hidden="true" class="w-11 h-11 bg-[#EFF2F7] rounded-lg flex items-center justify-center text-[#0F2557] font-black text-[18px] flex-shrink-0">✓</div>
        <div>
          <div class="text-[14px] font-black text-[#0F2557]">確定申告に対応</div>
          <div class="text-[12px] text-[#5A6B85] mt-0.5">収支を自動集計</div>
        </div>
      </div>

      <div class="flex items-center gap-4 px-7 py-5">
        <div aria-hidden="true" class="w-11 h-11 bg-[#EFF2F7] rounded-lg flex items-center justify-center text-[#0F2557] font-black text-[11px] flex-shrink-0">PC</div>
        <div>
          <div class="text-[14px] font-black text-[#0F2557]">データはお手元に</div>
          <div class="text-[12px] text-[#5A6B85] mt-0.5">クラウド送信なし</div>
        </div>
      </div>

    </div>

  </div>
</section>


<!-- ===== S2. こんな悩み ===== -->
<section class="bg-white rounded-t-[40px] sm:rounded-t-[80px] mt-[-40px]">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-[88px]">

    <!-- セクションヘッダー -->
    <div class="flex flex-col items-center gap-5 mb-12 reveal">
      <span
        class="inline-block font-bold"
        style="border:1.5px solid #0F2557; color:#0F2557; font-size:13px; font-weight:700; padding:8px 26px; border-radius:999px;"
      >PROBLEM — こんなお悩み、ありませんか？</span>
      <h2 style="font-size:31px; font-weight:900; color:#0F2557; letter-spacing:0.04em;" class="text-center">
        紙とExcelの管理、そろそろ限界かも。
      </h2>
    </div>

    <!-- カードグリッド -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-[18px] reveal-stagger">

      {painItems.map(item => (
        <div class="reveal bg-[#F3F6FB] rounded-[18px] p-7 flex flex-col gap-3">
          <div class="w-[38px] h-[38px] bg-white rounded-full text-[#B45309] font-black text-base flex items-center justify-center flex-shrink-0">!</div>
          <div class="text-[15.5px] font-black text-[#0F2557]">{item.title}</div>
          <div class="text-[13px] leading-[1.9] text-[#5A6B85]">{item.desc}</div>
        </div>
      ))}

      <!-- ネイビーアクセントカード -->
      <div class="reveal rounded-[18px] p-7 flex flex-col justify-center items-center" style="background:#0F2557;">
        <p class="text-[15px] font-black text-white leading-[1.7] text-center">
          ひとつでも当てはまった方へ。<br>その負担、道具で軽くできます。
        </p>
      </div>

    </div>
  </div>
</section>


<!-- ===== S3. こんな方 ===== -->
<section id="about" class="bg-white pb-[80px]">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">

    <!-- セクションヘッダー -->
    <div class="flex flex-col items-center gap-5 mb-12 reveal">
      <span
        class="inline-block font-bold"
        style="border:1.5px solid #0F2557; color:#0F2557; font-size:13px; font-weight:700; padding:8px 26px; border-radius:999px;"
      >FOR — どんな方に向いているか</span>
      <h2 style="font-size:31px; font-weight:900; color:#0F2557; letter-spacing:0.04em;" class="text-center">
        小さな建設業の、事務まわりの味方に。
      </h2>
    </div>

    <!-- カードグリッド -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-[18px] reveal-stagger">
      {targetTypes.map(t => (
        <div class="reveal border border-[#E3E8F0] rounded-[18px] p-8 flex flex-col gap-3">
          <span class="self-start bg-[#EFF2F7] text-[#0F2557] text-[11.5px] font-bold px-3.5 py-1 rounded-full">{t.tag}</span>
          <div class="text-[17px] font-black text-[#0F2557]">{t.title}</div>
          <div class="text-[13.5px] leading-[2] text-[#5A6B85]">{t.desc}</div>
        </div>
      ))}
    </div>

  </div>
</section>


<!-- ===== S4. できること ===== -->
<section class="relative overflow-clip" style="background:#0F2557; border-radius:80px 80px 0 0;">

  <!-- 装飾リング -->
  <div
    class="absolute pointer-events-none"
    aria-hidden="true"
    style="bottom:-200px; left:-180px; width:560px; height:560px; border:70px solid #14305F; border-radius:50%; z-index:0;"
  ></div>

  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-[88px] relative" style="z-index:1;">

    <!-- セクションヘッダー -->
    <div class="flex flex-col items-center gap-5 mb-12 reveal">
      <span
        class="inline-block font-bold"
        style="border:1px solid #4A5E8C; color:#DCE4F1; font-size:13px; font-weight:700; padding:8px 26px; border-radius:999px;"
      >SERVICE — 工房でできること</span>
      <h2 class="text-[31px] font-black text-white text-center" style="letter-spacing:0.04em;">
        道具と、ひな形と、情報の3本柱。
      </h2>
    </div>

    <!-- カードグリッド -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-[18px] reveal-stagger">
      {pillars.map(p => (
        <div class="reveal rounded-[18px] p-8 flex flex-col gap-3" style="background:#14305F;">
          <div class="font-mono text-[12px] text-[#F59E0B] font-medium">{p.num}</div>
          <div class="text-[18px] font-black text-white">{p.title}</div>
          <div class="text-[13.5px] leading-[2] text-[#C7D2E5]">{p.desc}</div>
        </div>
      ))}
    </div>

  </div>
</section>


<!-- ===== S5. 注目の商品 ===== -->
<section id="products" class="bg-white rounded-t-[40px] sm:rounded-t-[80px] mt-[-40px]">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-[88px]">

    <!-- セクションヘッダー -->
    <div class="flex flex-col items-center gap-5 mb-12 reveal">
      <span
        class="inline-block font-bold"
        style="border:1.5px solid #0F2557; color:#0F2557; font-size:13px; font-weight:700; padding:8px 26px; border-radius:999px;"
      >PRODUCT — ツール・ラインナップ</span>
      <h2 style="font-size:31px; font-weight:900; color:#0F2557; letter-spacing:0.04em;" class="text-center">
        道具をそろえて、現場をシンプルに。
      </h2>
    </div>

    <!-- 3列ラインナップ -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-[18px] reveal-stagger">

      <!-- 第1弾: 発売中 -->
      <div class="reveal border border-[#0F2557] rounded-[18px] p-7 flex flex-col gap-3">
        <div class="flex gap-2 flex-wrap">
          <span class="bg-[#F59E0B] text-white text-[11px] font-bold px-3 py-0.5 rounded-full">発売中</span>
          <span class="border border-[#0F2557] text-[#0F2557] text-[11px] font-bold px-3 py-0.5 rounded-full">第1弾</span>
        </div>
        <div class="text-[17px] font-black text-[#0F2557]">シンプル工事台帳 ライト版</div>
        <div class="text-[13px] leading-[1.9] text-[#5A6B85]">
          工事の収支を記録・集計し、確定申告の準備までつながるExcel工事台帳。マクロなし・買い切り。
        </div>
        <div class="mt-auto pt-3 border-t border-[#E3E8F0] flex items-baseline gap-2">
          <span class="text-[22px] font-black text-[#0F2557]">¥{PRODUCT.price.toLocaleString()}</span>
          <span class="text-[12px] text-[#5A6B85]">税込・買い切り</span>
        </div>
        <a href="/products/koji-daicho/" class="mt-1 bg-[#0F2557] hover:bg-[#1B3463] text-white font-bold text-[14px] px-5 py-3 rounded-lg text-center btn-press transition-colors">商品ページを見る →</a>
      </div>

      <!-- 第2弾: 発売中 -->
      <div class="reveal border border-[#0F2557] rounded-[18px] p-7 flex flex-col gap-3">
        <div class="flex gap-2 flex-wrap">
          <span class="bg-[#F59E0B] text-white text-[11px] font-bold px-3 py-0.5 rounded-full">発売中</span>
          <span class="border border-[#0F2557] text-[#0F2557] text-[11px] font-bold px-3 py-0.5 rounded-full">第2弾</span>
        </div>
        <div class="text-[17px] font-black text-[#0F2557]">シンプル安全台帳</div>
        <div class="text-[13px] leading-[1.9] text-[#5A6B85]">
          作業員の資格・健康診断、車両の車検・保険といった「期限もの」をひと目で管理し、安全書類づくりまでつなげるツール。
        </div>
        <div class="mt-auto pt-3 border-t border-[#E3E8F0] flex items-baseline gap-2">
          <span class="text-[22px] font-black text-[#0F2557]">¥9,800</span>
          <span class="text-[12px] text-[#5A6B85]">税込・買い切り</span>
        </div>
        <a href="/products/anzen-daicho/" class="mt-1 bg-[#0F2557] hover:bg-[#1B3463] text-white font-bold text-[14px] px-5 py-3 rounded-lg text-center btn-press transition-colors">商品ページを見る →</a>
      </div>

      <!-- 第3弾: 建設番頭 -->
      <div class="reveal border border-[#0F2557] rounded-[18px] p-7 flex flex-col gap-3">
        <div class="flex gap-2 flex-wrap">
          <span class="bg-[#F59E0B] text-white text-[11px] font-bold px-3 py-0.5 rounded-full">発売中</span>
          <span class="border border-[#0F2557] text-[#0F2557] text-[11px] font-bold px-3 py-0.5 rounded-full">第3弾</span>
        </div>
        <div class="text-[17px] font-black text-[#0F2557]">建設番頭</div>
        <div class="text-[13px] leading-[1.9] text-[#5A6B85]">
          工事原価・資金繰りを一本化する小規模建設許可業者向けツール。「黒字なのにお金が足りない」を、起こる前に気づけます。
        </div>
        <div class="mt-auto pt-3 border-t border-[#E3E8F0] flex items-baseline gap-2">
          <span class="text-[22px] font-black text-[#0F2557]">¥19,800</span>
          <span class="text-[12px] text-[#5A6B85]">税込・買い切り</span>
        </div>
        <a href="/products/kensetsu-banto/" class="mt-1 bg-[#0F2557] hover:bg-[#1B3463] text-white font-bold text-[14px] px-5 py-3 rounded-lg text-center btn-press transition-colors">商品ページを見る →</a>
      </div>

    </div>

  </div>
</section>


<!-- ===== S6. 最新の記事 ===== -->
<section id="blog" class="bg-[#F3F6FB]">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-[88px]">

    <!-- セクションヘッダー -->
    <div class="flex flex-col items-center gap-5 mb-12 reveal">
      <span
        class="inline-block font-bold"
        style="border:1.5px solid #0F2557; color:#0F2557; font-size:13px; font-weight:700; padding:8px 26px; border-radius:999px;"
      >BLOG — 最新の記事</span>
      <h2 style="font-size:31px; font-weight:900; color:#0F2557; letter-spacing:0.04em;" class="text-center">
        実務に効く情報を、無料で。
      </h2>
    </div>

    <!-- 記事グリッド -->
    {posts.length > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-[18px] reveal-stagger mb-10">
        {posts.map(post => (
          <a
            href={`/blog/${post.slug}/`}
            class="reveal group bg-white rounded-[18px] overflow-hidden flex flex-col no-underline text-inherit"
            style="box-shadow: var(--shadow-sm); transition:box-shadow 0.2s ease,transform 0.2s ease;"
          >
            <!-- コンテンツ -->
            <div class="p-6 flex flex-col gap-2.5 flex-1">
              <div class="flex gap-2.5 items-center text-xs text-[#5A6B85]">
                {post.data.category && (
                  <span class="bg-[#EFF2F7] rounded-full px-3 py-0.5 font-bold text-[#0F2557]">{post.data.category}</span>
                )}
                <span class="font-mono">
                  {post.data.publishedAt.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '.')}
                </span>
              </div>
              <div class="text-[15px] font-bold leading-[1.7] text-[#0F2557]">{post.data.title}</div>
              <div class="text-[13px] font-bold text-[#F59E0B] mt-auto">読む →</div>
            </div>
          </a>
        ))}
      </div>
    )}

    <!-- 記事一覧リンク -->
    <div class="flex justify-center mb-12 reveal">
      <a
        href="/blog/"
        class="font-bold text-[14px] transition-colors hover:bg-[#0F2557] hover:text-white"
        style="border:1.5px solid #0F2557; color:#0F2557; padding:13px 36px; border-radius:999px;"
      >記事一覧を見る →</a>
    </div>


  </div>
</section>


<!-- ===== 工房について ===== -->
<section class="bg-[#F3F6FB] pb-[80px]">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 reveal">
    <div class="bg-white border border-[#D8DEE8] rounded-[18px] flex flex-col sm:flex-row sm:items-center gap-6" style="padding:28px 36px;">

      <!-- キャラクター -->
      <div class="flex items-center gap-3 flex-shrink-0">
        <img
          src="/images/characters/uta_product.png"
          alt="黒猫のウタ"
          width="88"
          height="88"
          class="rounded-full"
          loading="lazy"
        />
        <img
          src="/images/characters/natu_product.png"
          alt="三毛猫のナツ"
          width="88"
          height="88"
          class="rounded-full"
          loading="lazy"
        />
      </div>

      <!-- テキスト -->
      <div class="text-[13.5px] leading-[1.9] text-[#44536E] flex-1">
        <strong class="text-[#0F2557]">ウタ</strong>と<strong class="text-[#0F2557]">ナツ</strong>が案内する「建設業ツール工房」は、一人親方や小規模な建設業の方が、事務まわりをもう少しらくにできるよう、道具と情報をつくっています。
      </div>

      <!-- CTAリンク -->
      <a
        href="/about/"
        class="flex-none font-bold text-[13.5px] text-[#0F2557] transition-colors hover:bg-[#0F2557] hover:text-white whitespace-nowrap"
        style="border:1.5px solid #0F2557; border-radius:999px; padding:11px 24px;"
      >工房について →</a>

    </div>
  </div>
</section>

</BaseLayout>
